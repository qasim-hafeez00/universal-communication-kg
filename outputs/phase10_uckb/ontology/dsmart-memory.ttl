@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix uckb:  <https://uckb.io/ontology#> .
@prefix dsmart: <https://uckb.io/ontology/dsmart#> .

# ─────────────────────────────────────────────────────────────────────────────
# UCKB Phase 10 — D-SMART Memory Ontology
# OWL ontology for the Dynamic Structured Memory And Reasoning Tree layer.
# 6 classes, 9 object properties, 8 datatype properties.
#
# Imports: uckb:temporal-memory (Phase 9) for Session and Turn alignment.
# ─────────────────────────────────────────────────────────────────────────────

<https://uckb.io/ontology/dsmart>
    a owl:Ontology ;
    dcterms:title "UCKB D-SMART Memory Ontology" ;
    dcterms:description "OWL ontology for Phase 10 Multi-Turn Logical Consistency layer. Models conversation fact extraction, goal tracking, protocol position monitoring, conflict detection, and reasoning tree candidate selection." ;
    dcterms:creator "UCKB Build Pipeline" ;
    dcterms:created "2026-05-31"^^xsd:date ;
    owl:versionInfo "1.0" ;
    owl:imports <https://uckb.io/ontology/temporal-memory> .


# ─────────────────────────────────────────────────────────────────────────────
# CLASSES
# ─────────────────────────────────────────────────────────────────────────────

dsmart:ConversationFact
    a owl:Class ;
    rdfs:label "Conversation Fact" ;
    rdfs:comment "An atomic, speaker-attributed fact extracted from a Turn by the Dynamic Structured Memory. Constitutes the live OWL-compliant conversation knowledge graph (DSM state)." ;
    rdfs:subClassOf uckb:KnowledgeNode ;
    skos:example "Subject states sister is inside the apartment (turn 1, information, caller)" .

dsmart:GoalState
    a owl:Class ;
    rdfs:label "Goal State" ;
    rdfs:comment "The inferred underlying user goal for a session as maintained by the RT. Tracks goal drift — when the agent starts responding to surface utterances rather than the underlying objective." ;
    rdfs:subClassOf uckb:KnowledgeNode ;
    skos:example "Goal: safety; status: active; detected at turn 1; confidence: 0.83" .

dsmart:ProtocolTracker
    a owl:Class ;
    rdfs:label "Protocol Tracker" ;
    rdfs:comment "Live protocol position and deviation counter. Bridges the static Phase 8 ProtocolDAG to the dynamic session. Increments deviationCount when steps are skipped or repeated." ;
    rdfs:subClassOf uckb:KnowledgeNode ;
    skos:example "BCSM tracker; currentStep=3; deviationCount=0; status=on_track" .

dsmart:ConsistencyConflict
    a owl:Class ;
    rdfs:label "Consistency Conflict" ;
    rdfs:comment "A detected contradiction logged into the DSM. Types: factual (claim vs claim), goal (drift detected), protocol (step deviation). Triggers NLI re-evaluation of pending candidate responses." ;
    rdfs:subClassOf uckb:KnowledgeNode ;
    skos:example "Factual critical: presence vs denial (turns 1 and 3)" .

dsmart:ReasoningCandidate
    a owl:Class ;
    rdfs:label "Reasoning Candidate" ;
    rdfs:comment "One candidate response path generated by the Reasoning Tree at a given turn before NLI selection. Carries nliScore, goalAlignment, protocolDeviation and compositeScore. Exactly one per turn group has selected=true." ;
    rdfs:subClassOf uckb:KnowledgeNode ;
    skos:example "Empathic reframe candidate; nliScore=0.71; compositeScore=0.799; selected=true" .

dsmart:ConsistencyReport
    a owl:Class ;
    rdfs:label "Consistency Report" ;
    rdfs:comment "Per-session DER (Dialogue Consistency Evaluation Rate) snapshot at a milestone turn. Records derScore, active fact count, unresolved conflict count, and protocol position at the time of evaluation." ;
    rdfs:subClassOf uckb:KnowledgeNode ;
    skos:example "Session 001, turn 4: derScore=0.67, factCount=5, conflictCount=2" .


# ─────────────────────────────────────────────────────────────────────────────
# OBJECT PROPERTIES
# ─────────────────────────────────────────────────────────────────────────────

dsmart:extractedFrom
    a owl:ObjectProperty ;
    rdfs:label "extracted from" ;
    rdfs:comment "Links a ConversationFact to the Turn it was extracted from." ;
    rdfs:domain dsmart:ConversationFact ;
    rdfs:range uckb:Turn .

dsmart:contradicts
    a owl:ObjectProperty , owl:SymmetricProperty ;
    rdfs:label "contradicts" ;
    rdfs:comment "Symmetric property: two ConversationFacts that are logically incompatible. Both directions are stored as separate edges." ;
    rdfs:domain dsmart:ConversationFact ;
    rdfs:range dsmart:ConversationFact .

dsmart:supersedes
    a owl:ObjectProperty , owl:IrreflexiveProperty ;
    rdfs:label "supersedes" ;
    rdfs:comment "A newer ConversationFact temporally invalidates an older one. The superseded fact has superseded=true and validUntil set to the transition turn." ;
    rdfs:domain dsmart:ConversationFact ;
    rdfs:range dsmart:ConversationFact .

dsmart:hasGoal
    a owl:ObjectProperty ;
    rdfs:label "has goal" ;
    rdfs:comment "Links a Session to its inferred GoalState." ;
    rdfs:domain uckb:Session ;
    rdfs:range dsmart:GoalState .

dsmart:hasTracker
    a owl:ObjectProperty ;
    rdfs:label "has tracker" ;
    rdfs:comment "Links a Session to its live ProtocolTracker." ;
    rdfs:domain uckb:Session ;
    rdfs:range dsmart:ProtocolTracker .

dsmart:tracks
    a owl:ObjectProperty ;
    rdfs:label "tracks" ;
    rdfs:comment "Links a ProtocolTracker to the ProtocolDAG it is monitoring position within." ;
    rdfs:domain dsmart:ProtocolTracker ;
    rdfs:range uckb:ProtocolDAG .

dsmart:candidateFor
    a owl:ObjectProperty ;
    rdfs:label "candidate for" ;
    rdfs:comment "Links a ReasoningCandidate to the Turn it was generated for." ;
    rdfs:domain dsmart:ReasoningCandidate ;
    rdfs:range uckb:Turn .

dsmart:hasReport
    a owl:ObjectProperty ;
    rdfs:label "has report" ;
    rdfs:comment "Links a Session to a ConsistencyReport DER snapshot." ;
    rdfs:domain uckb:Session ;
    rdfs:range dsmart:ConsistencyReport .

dsmart:flaggedDeviation
    a owl:ObjectProperty ;
    rdfs:label "flagged deviation" ;
    rdfs:comment "Links a ProtocolTracker to the ConsistencyConflict that was created when a protocol deviation was detected." ;
    rdfs:domain dsmart:ProtocolTracker ;
    rdfs:range dsmart:ConsistencyConflict .


# ─────────────────────────────────────────────────────────────────────────────
# DATATYPE PROPERTIES
# ─────────────────────────────────────────────────────────────────────────────

dsmart:factType
    a owl:DatatypeProperty ;
    rdfs:label "fact type" ;
    rdfs:comment "Semantic type of the extracted fact: commitment, position, information, denial." ;
    rdfs:domain dsmart:ConversationFact ;
    rdfs:range xsd:string .

dsmart:superseded
    a owl:DatatypeProperty ;
    rdfs:label "superseded" ;
    rdfs:comment "Boolean flag: true when this ConversationFact has been invalidated by a newer fact." ;
    rdfs:domain dsmart:ConversationFact ;
    rdfs:range xsd:boolean .

dsmart:goalStatus
    a owl:DatatypeProperty ;
    rdfs:label "goal status" ;
    rdfs:comment "Current lifecycle state of a GoalState: active, drifted, resolved, blocked." ;
    rdfs:domain dsmart:GoalState ;
    rdfs:range xsd:string .

dsmart:confidenceScore
    a owl:DatatypeProperty ;
    rdfs:label "confidence score" ;
    rdfs:comment "RT confidence in the current goal inference, in [0.0, 1.0]." ;
    rdfs:domain dsmart:GoalState ;
    rdfs:range xsd:decimal .

dsmart:deviationCount
    a owl:DatatypeProperty ;
    rdfs:label "deviation count" ;
    rdfs:comment "Number of protocol step deviations (skips or repeats) counted by the ProtocolTracker." ;
    rdfs:domain dsmart:ProtocolTracker ;
    rdfs:range xsd:integer .

dsmart:nliScore
    a owl:DatatypeProperty ;
    rdfs:label "NLI score" ;
    rdfs:comment "Natural Language Inference consistency score of a ReasoningCandidate against current DSM state, in [0.0, 1.0]." ;
    rdfs:domain dsmart:ReasoningCandidate ;
    rdfs:range xsd:decimal .

dsmart:compositeScore
    a owl:DatatypeProperty ;
    rdfs:label "composite score" ;
    rdfs:comment "Weighted composite selection score: 0.5*nliScore + 0.3*goalAlignment + 0.2*(1-protocolDeviation)." ;
    rdfs:domain dsmart:ReasoningCandidate ;
    rdfs:range xsd:decimal .

dsmart:derScore
    a owl:DatatypeProperty ;
    rdfs:label "DER score" ;
    rdfs:comment "Dialogue Consistency Evaluation Rate — overall consistency score for a session at the snapshot turn, in [0.0, 1.0]. Benchmarked against MT-Bench-101; D-SMART shows >=48% improvement over baseline." ;
    rdfs:domain dsmart:ConsistencyReport ;
    rdfs:range xsd:decimal .
