    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "When the patient goes silent after difficult news or a question, hold the silence — do not rush to fill it; after 8-10 seconds, ask gently: 'What is going through your mind right now?'; validate whatever they share before proceeding."^^xsd:string ;
    uckb:successSignals "Patient can explain the issue, options, risks, and next action in their own words."^^xsd:string ;
    uckb:switchTo "Teach-Back; SPIKES Emotion; Follow-Up Safety Net"^^xsd:string ;
