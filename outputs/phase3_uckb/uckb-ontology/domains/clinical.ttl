    uckb:culturalNotes "Respect family roles, privacy, face-saving, and interpreter needs with patient consent."^^xsd:string ;
    uckb:description "MI technique exploring the advantages and disadvantages of both change and status quo, supporting autonomous patient decision-making."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Question; Acknowledge; Confirm; Suggest"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Crisis dispatch health instruction; sales shared-decision analogue"^^xsd:string ;
