@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix uckb: <https://uckb.io/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

uckb:clinical_001_spikes_setting a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "SPIKES Setting" ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_disclosure_setting ;
    uckb:PRECEDES uckb:SPIKES_Perception ;
    uckb:REQUIRES uckb:consent-sensitive_setup ;
    uckb:cardId "clinical_001_spikes_setting"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium"^^xsd:string ;
    uckb:contraindications "Do not disclose sensitive information in unsafe setting unless clinically necessary."^^xsd:string ;
    uckb:culturalNotes "Family involvement norms vary; ask preference."^^xsd:string ;
    uckb:description "Prepares privacy, participants, time, and environment for serious disclosure."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Request; Confirm"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Crisis disclosure setting"^^xsd:string ;
    uckb:failureSignals "Patient is distracted, unsafe, or unsupported."^^xsd:string ;
    uckb:name "SPIKES Setting"^^xsd:string ;
    uckb:requiredEdges "PRECEDES SPIKES Perception; REQUIRES consent-sensitive setup"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Arrange privacy; confirm participants; reduce interruptions; establish agenda."^^xsd:string ;
    uckb:successSignals "Patient indicates readiness and privacy is adequate."^^xsd:string ;
    uckb:switchTo "SPIKES Perception; Invitation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "privacy_concern; anxiety_signal"^^xsd:string ;
    uckb:whenNotToUse "Immediate life-saving instruction is required."^^xsd:string ;
    uckb:whenToUse "Before delivering serious or sensitive clinical information."^^xsd:string .

uckb:clinical_002_spikes_perception a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "SPIKES Perception" ;
    uckb:DOMAIN_VARIANT_OF uckb:Negotiation_baseline_elicitation ;
    uckb:FOLLOWS uckb:Setting ;
    uckb:PRECEDES uckb:Invitation ;
    uckb:cardId "clinical_002_spikes_perception"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-to-medium"^^xsd:string ;
    uckb:contraindications "Do not quiz or shame the patient."^^xsd:string ;
    uckb:culturalNotes "Use face-saving correction."^^xsd:string ;
    uckb:description "Elicits patient understanding before disclosure."^^xsd:string ;
    uckb:dialogueActLinks "Question; Inform; Feedback"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Negotiation baseline elicitation"^^xsd:string ;
    uckb:failureSignals "Patient becomes more confused or distressed."^^xsd:string ;
    uckb:name "SPIKES Perception"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Setting; PRECEDES Invitation"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Ask what patient understands; listen; correct gently."^^xsd:string ;
    uckb:successSignals "Baseline understanding is clear."^^xsd:string ;
    uckb:switchTo "SPIKES Invitation; Teach-Back"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "repair_request; misunderstanding"^^xsd:string ;
    uckb:whenNotToUse "Patient is unstable and needs immediate intervention."^^xsd:string ;
    uckb:whenToUse "Before giving bad news or complex diagnosis."^^xsd:string .

uckb:clinical_003_spikes_invitation a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "SPIKES Invitation" ;
    uckb:DOMAIN_VARIANT_OF uckb:Consent_checkpoint ;
    uckb:FOLLOWS uckb:Perception ;
    uckb:PRECEDES uckb:Knowledge ;
    uckb:cardId "clinical_003_spikes_invitation"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low"^^xsd:string ;
    uckb:contraindications "Do not dump information without invitation."^^xsd:string ;
    uckb:culturalNotes "Preference for family-mediated disclosure varies."^^xsd:string ;
    uckb:description "Asks how much detail the patient wants and whether to proceed."^^xsd:string ;
    uckb:dialogueActLinks "Request; Accept; Decline"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Consent checkpoint"^^xsd:string ;
    uckb:failureSignals "Patient feels abandoned or overwhelmed."^^xsd:string ;
    uckb:name "SPIKES Invitation"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Perception; PRECEDES Knowledge"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Ask preference; honor limits; offer to pause."^^xsd:string ;
    uckb:successSignals "Patient chooses level of detail."^^xsd:string ;
    uckb:switchTo "SPIKES Knowledge; Pause"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "anxiety_signal; silence_after_prompt"^^xsd:string ;
    uckb:whenNotToUse "Required emergency disclosure cannot wait."^^xsd:string ;
    uckb:whenToUse "Before detailed disclosure."^^xsd:string .

uckb:clinical_004_spikes_knowledge a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "SPIKES Knowledge" ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_knowledge_delivery ;
    uckb:FOLLOWS uckb:Invitation ;
    uckb:PRECEDES uckb:Emotion ;
    uckb:cardId "clinical_004_spikes_knowledge"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-to-medium"^^xsd:string ;
    uckb:contraindications "Avoid jargon, false certainty, or excessive detail."^^xsd:string ;
    uckb:culturalNotes "Adjust directness and family norms."^^xsd:string ;
    uckb:description "Delivers medical information in small, plain-language chunks."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Check-Question"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Crisis knowledge delivery"^^xsd:string ;
    uckb:failureSignals "Patient shuts down, dissociates, or asks repeated repair."^^xsd:string ;
    uckb:name "SPIKES Knowledge"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Invitation; PRECEDES Emotion"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Warn gently; state key point; pause; check understanding."^^xsd:string ;
    uckb:successSignals "Patient can restate key information."^^xsd:string ;
    uckb:switchTo "SPIKES Emotion; Teach-Back"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "repair_request; grief_marker"^^xsd:string ;
    uckb:whenNotToUse "Patient is overwhelmed or has declined detail."^^xsd:string ;
    uckb:whenToUse "Patient has invited information."^^xsd:string .

uckb:clinical_005_spikes_emotion a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "SPIKES Emotion" ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_empathic_validation ;
    uckb:FOLLOWS uckb:Knowledge ;
    uckb:PRECEDES uckb:Strategy ;
    uckb:cardId "clinical_005_spikes_emotion"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low"^^xsd:string ;
    uckb:contraindications "Do not problem-solve before emotion is acknowledged."^^xsd:string ;
    uckb:culturalNotes "Silence may be respect, grief, or processing."^^xsd:string ;
    uckb:description "Responds to emotion with empathic naming and support."^^xsd:string ;
    uckb:dialogueActLinks "Acknowledge; Feedback"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Crisis empathic validation"^^xsd:string ;
    uckb:failureSignals "Patient feels dismissed or rushed."^^xsd:string ;
    uckb:name "SPIKES Emotion"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Knowledge; PRECEDES Strategy"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Observe emotion; name gently; validate; pause."^^xsd:string ;
    uckb:successSignals "Patient continues engagement or accepts support."^^xsd:string ;
    uckb:switchTo "SPIKES Strategy; Motivational Interviewing"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "grief_marker; silence_after_prompt"^^xsd:string ;
    uckb:whenNotToUse "Patient needs immediate medical action first."^^xsd:string ;
    uckb:whenToUse "Patient shows grief, anger, fear, or silence after news."^^xsd:string .

uckb:clinical_006_spikes_strategy a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "SPIKES Strategy" ;
    uckb:DOMAIN_VARIANT_OF uckb:Negotiation_mutual_action_plan_analogue ;
    uckb:ENHANCES uckb:Teach-Back ;
    uckb:FOLLOWS uckb:Emotion ;
    uckb:cardId "clinical_006_spikes_strategy"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium"^^xsd:string ;
    uckb:contraindications "Do not force decision under overload."^^xsd:string ;
    uckb:culturalNotes "Include family/authority preferences with consent."^^xsd:string ;
    uckb:description "Collaborative plan after disclosure and emotional response."^^xsd:string ;
    uckb:dialogueActLinks "Suggest; Offer; Confirm"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Negotiation mutual action plan analogue"^^xsd:string ;
    uckb:failureSignals "Patient cannot restate plan."^^xsd:string ;
    uckb:name "SPIKES Strategy"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Emotion; ENHANCES Teach-Back"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Summarize; offer options; agree next step; check support."^^xsd:string ;
    uckb:successSignals "Patient understands plan and next contact."^^xsd:string ;
    uckb:switchTo "Teach-Back; Follow-Up Safety Net"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "teach_back_failure; overload"^^xsd:string ;
    uckb:whenNotToUse "Patient remains in acute shock or confusion."^^xsd:string ;
    uckb:whenToUse "Patient is oriented enough to discuss next steps."^^xsd:string .

uckb:clinical_007_motivational_interviewing_oars a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Motivational Interviewing OARS" ;
    uckb:CONTRADICTS uckb:Directive_Shaming ;
    uckb:DOMAIN_VARIANT_OF uckb:Sales_discovery_analogue ;
    uckb:ENHANCES uckb:Change_Talk ;
    uckb:cardId "clinical_007_motivational_interviewing_oars"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium"^^xsd:string ;
    uckb:contraindications "Do not use as covert persuasion."^^xsd:string ;
    uckb:culturalNotes "Autonomy language should fit cultural decision norms."^^xsd:string ;
    uckb:description "Open questions, affirmations, reflections, and summaries that support autonomy."^^xsd:string ;
    uckb:dialogueActLinks "Question; Acknowledge; Summarize"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Sales discovery analogue"^^xsd:string ;
    uckb:failureSignals "Patient feels judged or coerced."^^xsd:string ;
    uckb:name "Motivational Interviewing OARS"^^xsd:string ;
    uckb:requiredEdges "ENHANCES Change Talk; CONTRADICTS Directive Shaming"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Ask open question; affirm strength; reflect; summarize change talk."^^xsd:string ;
    uckb:successSignals "Patient articulates own reason for change."^^xsd:string ;
    uckb:switchTo "Change Talk Elicitation; Teach-Back"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "ambivalence; sustain_talk"^^xsd:string ;
    uckb:whenNotToUse "Acute crisis or coercive context."^^xsd:string ;
    uckb:whenToUse "Behavior change conversation with ambivalence."^^xsd:string .

uckb:clinical_008_teach_back a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Teach-Back" ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_instruction_confirmation ;
    uckb:FOLLOWS uckb:Knowledge ;
    uckb:RESOLVES uckb:Comprehension_Gap ;
    uckb:cardId "clinical_008_teach_back"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low"^^xsd:string ;
    uckb:contraindications "Never frame as testing patient intelligence."^^xsd:string ;
    uckb:culturalNotes "Use humble clinician framing."^^xsd:string ;
    uckb:description "Asks patient to explain plan in their own words to verify comprehension."^^xsd:string ;
    uckb:dialogueActLinks "Check-Question; Inform; Confirm"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Crisis instruction confirmation"^^xsd:string ;
    uckb:failureSignals "Patient cannot explain plan or feels tested."^^xsd:string ;
    uckb:name "Teach-Back"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Knowledge; RESOLVES Comprehension Gap"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Normalize check; ask patient to restate; clarify; re-check."^^xsd:string ;
    uckb:successSignals "Patient accurately restates plan."^^xsd:string ;
    uckb:switchTo "Plain-Language Rephrase; Follow-Up Safety Net"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "repair_request; nodding_without_restatement"^^xsd:string ;
    uckb:whenNotToUse "Patient is too distressed and needs stabilization first."^^xsd:string ;
    uckb:whenToUse "After instructions, diagnosis, medication plan, or discharge plan."^^xsd:string .

uckb:clinical_009_plain_language_rephrase a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Plain-Language Rephrase" ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_plain_instruction ;
    uckb:ENHANCES uckb:Teach-Back ;
    uckb:TRIGGERED_BY uckb:Repair_Request ;
    uckb:cardId "clinical_009_plain_language_rephrase"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low"^^xsd:string ;
    uckb:contraindications "Do not oversimplify safety-critical distinctions."^^xsd:string ;
    uckb:culturalNotes "Use culturally familiar examples only when safe."^^xsd:string ;
    uckb:description "Re-expresses clinical information without jargon."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Repair"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Crisis plain instruction"^^xsd:string ;
    uckb:failureSignals "Patient repeats misunderstanding."^^xsd:string ;
    uckb:name "Plain-Language Rephrase"^^xsd:string ;
    uckb:requiredEdges "TRIGGERED_BY Repair Request; ENHANCES Teach-Back"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Use common words; define unavoidable term; check understanding."^^xsd:string ;
    uckb:successSignals "Patient asks relevant next question."^^xsd:string ;
    uckb:switchTo "Teach-Back; Visual Analogy"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "medical_jargon_confusion; repair_request"^^xsd:string ;
    uckb:whenNotToUse "Precision would be lost and clinician must retain exact term with explanation."^^xsd:string ;
    uckb:whenToUse "Patient shows confusion or low health literacy signs."^^xsd:string .

uckb:clinical_010_follow_up_safety_net a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Follow-Up Safety Net" ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_callback_instruction ;
    uckb:FOLLOWS uckb:Strategy ;
    uckb:REQUIRES uckb:Teach-Back_where_possible ;
    uckb:cardId "clinical_010_follow_up_safety_net"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low"^^xsd:string ;
    uckb:contraindications "Do not provide false reassurance."^^xsd:string ;
    uckb:culturalNotes "Adapt contact route to local access and family support."^^xsd:string ;
    uckb:description "Clear guidance on what to watch for and when to seek help."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Directive; Confirm"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Crisis callback instruction"^^xsd:string ;
    uckb:failureSignals "Patient leaves with vague reassurance only."^^xsd:string ;
    uckb:name "Follow-Up Safety Net"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Strategy; REQUIRES Teach-Back where possible"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "State warning signs; state contact path; confirm ability."^^xsd:string ;
    uckb:successSignals "Patient knows next action if condition changes."^^xsd:string ;
    uckb:switchTo "Teach-Back; Escalation Protocol"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "uncertainty; anxiety_signal"^^xsd:string ;
    uckb:whenNotToUse "Immediate emergency action required now."^^xsd:string ;
    uckb:whenToUse "After plan, discharge, uncertainty, or watchful waiting."^^xsd:string .

uckb:clinical_011_ask_tell_ask a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Ask-Tell-Ask" ;
    uckb:CONTRAINDICATED_WHEN uckb:acute_instability ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_dispatch_health_instruction,
        uckb:sales_shared-decision_analogue ;
    uckb:ENHANCES uckb:Teach-Back ;
    uckb:REQUIRES uckb:Consent_Checkpoint_where_sensitive ;
    uckb:cardId "clinical_011_ask_tell_ask"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-to-medium; lower when distress or confusion appears"^^xsd:string ;
    uckb:contraindications "Do not replace licensed clinical judgment, emergency protocol, or consent requirements."^^xsd:string ;
    uckb:culturalNotes "Respect family roles, privacy, face-saving, and interpreter needs with patient consent."^^xsd:string ;
    uckb:description "Three-step MI-derived exchange that tests existing knowledge, provides targeted information, and confirms comprehension afterward."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Question; Acknowledge; Confirm; Suggest"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Crisis dispatch health instruction; sales shared-decision analogue"^^xsd:string ;
    uckb:failureSignals "Patient shows confusion, shame, withdrawal, repeated repair requests, or unsafe plan interpretation."^^xsd:string ;
    uckb:name "Ask-Tell-Ask"^^xsd:string ;
    uckb:requiredEdges "REQUIRES Consent Checkpoint where sensitive; ENHANCES Teach-Back; CONTRAINDICATED_WHEN acute instability"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Ask what the patient already knows about the topic; tell only what is needed to address the specific gaps identified; ask again what the patient understood from what you told them; adjust the next tell based on what they demonstrate."^^xsd:string ;
    uckb:successSignals "Patient can explain the issue, options, risks, and next action in their own words."^^xsd:string ;
    uckb:switchTo "Teach-Back; SPIKES Emotion; Follow-Up Safety Net"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "repair_request; silence_after_prompt; grief_marker; medical_jargon_confusion; teach_back_failure"^^xsd:string ;
    uckb:whenNotToUse "Do not use when emergency intervention, specialist escalation, or local clinical protocol overrides conversational sequencing."^^xsd:string ;
    uckb:whenToUse "Use when clinical information, behavior change, uncertainty, emotion, or comprehension risk must be managed."^^xsd:string .

uckb:clinical_012_elicit_provide_elicit a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Elicit-Provide-Elicit" ;
    uckb:CONTRAINDICATED_WHEN uckb:acute_instability ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_dispatch_health_instruction,
        uckb:sales_shared-decision_analogue ;
    uckb:ENHANCES uckb:Teach-Back ;
    uckb:REQUIRES uckb:Consent_Checkpoint_where_sensitive ;
    uckb:cardId "clinical_012_elicit_provide_elicit"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-to-medium; lower when distress or confusion appears"^^xsd:string ;
    uckb:contraindications "Do not replace licensed clinical judgment, emergency protocol, or consent requirements."^^xsd:string ;
    uckb:culturalNotes "Respect family roles, privacy, face-saving, and interpreter needs with patient consent."^^xsd:string ;
    uckb:description "MI-aligned information exchange that elicits current understanding, provides tailored information, and elicits the patient's response."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Question; Acknowledge; Confirm; Suggest"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Crisis dispatch health instruction; sales shared-decision analogue"^^xsd:string ;
    uckb:failureSignals "Patient shows confusion, shame, withdrawal, repeated repair requests, or unsafe plan interpretation."^^xsd:string ;
    uckb:name "Elicit-Provide-Elicit"^^xsd:string ;
    uckb:requiredEdges "REQUIRES Consent Checkpoint where sensitive; ENHANCES Teach-Back; CONTRAINDICATED_WHEN acute instability"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "Elicit the patient's current understanding or concern; provide information in direct response to what they asked or expressed; elicit the patient's reaction to what was provided; repeat the cycle until comprehension and acceptance are confirmed."^^xsd:string ;
    uckb:successSignals "Patient can explain the issue, options, risks, and next action in their own words."^^xsd:string ;
    uckb:switchTo "Teach-Back; SPIKES Emotion; Follow-Up Safety Net"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "repair_request; silence_after_prompt; grief_marker; medical_jargon_confusion; teach_back_failure"^^xsd:string ;
    uckb:whenNotToUse "Do not use when emergency intervention, specialist escalation, or local clinical protocol overrides conversational sequencing."^^xsd:string ;
    uckb:whenToUse "Use when clinical information, behavior change, uncertainty, emotion, or comprehension risk must be managed."^^xsd:string .

uckb:clinical_013_change_talk_elicitation a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Change Talk Elicitation" ;
    uckb:CONTRAINDICATED_WHEN uckb:acute_instability ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_dispatch_health_instruction,
