    uckb:name "Risk Communication Absolute Terms"^^xsd:string ;
    uckb:requiredEdges "REQUIRES Consent Checkpoint where sensitive; ENHANCES Teach-Back; CONTRAINDICATED_WHEN acute instability"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "State risk as a natural frequency: 'X out of 100 patients'; avoid percentage-only presentation for complex or small risks; compare to a relevant baseline rate; use a visual aid if available and appropriate."^^xsd:string ;
    uckb:successSignals "Patient can explain the issue, options, risks, and next action in their own words."^^xsd:string ;
