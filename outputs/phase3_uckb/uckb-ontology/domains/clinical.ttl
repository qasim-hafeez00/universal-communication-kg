    uckb:CONTRAINDICATED_WHEN uckb:acute_instability ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_dispatch_health_instruction,
        uckb:sales_shared-decision_analogue ;
    uckb:ENHANCES uckb:Teach-Back ;
    uckb:REQUIRES uckb:Consent_Checkpoint_where_sensitive ;
    uckb:cardId "clinical_024_risk_communication_relative_terms"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-to-medium; lower when distress or confusion appears"^^xsd:string ;
    uckb:contraindications "Do not replace licensed clinical judgment, emergency protocol, or consent requirements."^^xsd:string ;
    uckb:culturalNotes "Respect family roles, privacy, face-saving, and interpreter needs with patient consent."^^xsd:string ;
    uckb:description "Presentation of relative risk always anchored to an absolute baseline to prevent misinterpretation of proportional risk language."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Question; Acknowledge; Confirm; Suggest"^^xsd:string ;
    uckb:domain "Clinical / Medical"^^xsd:string ;
    uckb:domainVariants "Crisis dispatch health instruction; sales shared-decision analogue"^^xsd:string ;
    uckb:failureSignals "Patient shows confusion, shame, withdrawal, repeated repair requests, or unsafe plan interpretation."^^xsd:string ;
    uckb:name "Risk Communication Relative Terms"^^xsd:string ;
    uckb:requiredEdges "REQUIRES Consent Checkpoint where sensitive; ENHANCES Teach-Back; CONTRAINDICATED_WHEN acute instability"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S009; S010"^^xsd:string ;
    uckb:steps "State relative risk and immediately anchor it to an absolute baseline; example: 'This doubles the risk — going from 1 in 1000 to 2 in 1000'; always provide both relative and absolute figures together; confirm the patient understood the absolute, not just the relative, figure."^^xsd:string ;
    uckb:successSignals "Patient can explain the issue, options, risks, and next action in their own words."^^xsd:string ;
    uckb:switchTo "Teach-Back; SPIKES Emotion; Follow-Up Safety Net"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "repair_request; silence_after_prompt; grief_marker; medical_jargon_confusion; teach_back_failure"^^xsd:string ;
    uckb:whenNotToUse "Do not use when emergency intervention, specialist escalation, or local clinical protocol overrides conversational sequencing."^^xsd:string ;
    uckb:whenToUse "Use when clinical information, behavior change, uncertainty, emotion, or comprehension risk must be managed."^^xsd:string .

