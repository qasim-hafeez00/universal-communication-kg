@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix uckb: <https://uckb.io/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

uckb:crisis_dispatch_001_active_listening a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Active Listening" ;
    uckb:DOMAIN_VARIANT_OF uckb:Reflective_Listening,
        uckb:SOLER,
        uckb:Tactical_Empathy ;
    uckb:ENHANCES uckb:Rapport ;
    uckb:PRECEDES uckb:Empathic_Validation ;
    uckb:cardId "crisis_dispatch_001_active_listening"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-load preferred"^^xsd:string ;
    uckb:contraindications "Do not use as delay when immediate evacuation or safety instruction is required."^^xsd:string ;
    uckb:culturalNotes "Allow silence in high-context interactions; do not rush to fill respectful pauses."^^xsd:string ;
    uckb:description "Full attentional processing of verbal and nonverbal signals with reflective feedback."^^xsd:string ;
    uckb:dialogueActLinks "Acknowledge; Clarify; Feedback-Positive"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Tactical Empathy; SOLER; Reflective Listening"^^xsd:string ;
    uckb:failureSignals "Caller repeats grievance; silence lengthens after direct question; contempt appears."^^xsd:string ;
    uckb:name "Active Listening"^^xsd:string ;
    uckb:requiredEdges "ENHANCES Rapport; PRECEDES Empathic Validation"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Attend; paraphrase; label emotion; ask one clarifying question."^^xsd:string ;
    uckb:successSignals "Caller elaborates; speech rate normalizes; repair requests decrease."^^xsd:string ;
    uckb:switchTo "Empathic Validation; Grounding; One-Step Instruction"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "filler_increase; repair_request; silence_after_prompt"^^xsd:string ;
    uckb:whenNotToUse "Time-critical command must be delivered immediately to prevent harm."^^xsd:string ;
    uckb:whenToUse "User shows confusion, distress, hostility, or fragmented narration."^^xsd:string .

uckb:crisis_dispatch_002_empathic_validation a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Empathic Validation" ;
    uckb:CONTRADICTS uckb:Dismissive_Reassurance ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_Empathic_Validation,
        uckb:Negotiation_Tactical_Empathy ;
    uckb:PRECEDES uckb:Rapport ;
    uckb:REQUIRES uckb:Active_Listening ;
    uckb:cardId "crisis_dispatch_002_empathic_validation"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-load"^^xsd:string ;
    uckb:contraindications "Never validate delusional content as fact; validate feelings only."^^xsd:string ;
    uckb:culturalNotes "Use face-saving phrasing where direct naming could shame the caller."^^xsd:string ;
    uckb:description "Acknowledges emotional reality without endorsing unsupported facts."^^xsd:string ;
    uckb:dialogueActLinks "Acknowledge; Inform; Repair"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Clinical Empathic Validation; Negotiation Tactical Empathy"^^xsd:string ;
    uckb:failureSignals "Caller says agent is not listening; escalation continues."^^xsd:string ;
    uckb:name "Empathic Validation"^^xsd:string ;
    uckb:requiredEdges "REQUIRES Active Listening; PRECEDES Rapport; CONTRADICTS Dismissive Reassurance"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Name emotion; connect to situation; avoid blame; move to next safe fact."^^xsd:string ;
    uckb:successSignals "Caller accepts next question; affect intensity drops."^^xsd:string ;
    uckb:switchTo "Grounding; Safety Fact Elicitation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "self_blame; volume_spike; absolutist_language"^^xsd:string ;
    uckb:whenNotToUse "Caller requests factual confirmation that is unknown or unsafe."^^xsd:string ;
    uckb:whenToUse "Caller expresses fear, anger, grief, shame, or helplessness."^^xsd:string .

uckb:crisis_dispatch_003_grounding a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Grounding" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_grounding,
        uckb:trauma-informed_grounding ;
    uckb:PRECEDES uckb:Instruction ;
    uckb:RESOLVES uckb:Cognitive_Overload ;
    uckb:TRIGGERED_BY uckb:Panic ;
    uckb:cardId "crisis_dispatch_003_grounding"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "lowest-load"^^xsd:string ;
    uckb:contraindications "Do not use as substitute for emergency escalation."^^xsd:string ;
    uckb:culturalNotes "Avoid culturally alien metaphors; use plain observable cues."^^xsd:string ;
    uckb:description "Short present-focused prompts that restore orientation and reduce arousal."^^xsd:string ;
    uckb:dialogueActLinks "Directive; Clarify; Confirm"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Clinical grounding; trauma-informed grounding"^^xsd:string ;
    uckb:failureSignals "Caller becomes more disoriented or cannot comply."^^xsd:string ;
    uckb:name "Grounding"^^xsd:string ;
    uckb:requiredEdges "TRIGGERED_BY Panic; RESOLVES Cognitive Overload; PRECEDES Instruction"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Orient to present; ask sensory or location cue; give one concrete next action."^^xsd:string ;
    uckb:successSignals "Caller answers simple fact; breathing or speech pace stabilizes."^^xsd:string ;
    uckb:switchTo "One-Step Instruction; Active Listening"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "speech_rate_spike; self_blame; long_silence"^^xsd:string ;
    uckb:whenNotToUse "Caller is in immediate physical danger requiring movement first."^^xsd:string ;
    uckb:whenToUse "Panic, dissociation risk, overwhelming fear, or fragmented narration."^^xsd:string .

uckb:crisis_dispatch_004_one_step_instruction a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "One-Step Instruction" ;
    uckb:CONTRAINDICATED_WHEN uckb:severe_dissociation_without_specialist_routing ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_safety_instruction ;
    uckb:FOLLOWS uckb:Grounding ;
    uckb:cardId "crisis_dispatch_004_one_step_instruction"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "lowest-load"^^xsd:string ;
    uckb:contraindications "Do not stack multi-step commands in one turn."^^xsd:string ;
    uckb:culturalNotes "Prefer direct language for safety while preserving respect."^^xsd:string ;
    uckb:description "A single concrete instruction delivered without competing information."^^xsd:string ;
    uckb:dialogueActLinks "Directive; Check-Question"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Clinical safety instruction"^^xsd:string ;
    uckb:failureSignals "Caller asks repeated repair questions or performs wrong action."^^xsd:string ;
    uckb:name "One-Step Instruction"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Grounding; CONTRAINDICATED_WHEN severe dissociation without specialist routing"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Say one action; wait; confirm completion; proceed to next action."^^xsd:string ;
    uckb:successSignals "Caller completes action; confirms location or safety status."^^xsd:string ;
    uckb:switchTo "Repeat/Rephrase; Dispatch Escalation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "panic_state; repair_request; cognitive_overload"^^xsd:string ;
    uckb:whenNotToUse "User is stable enough for collaborative planning or needs informed consent first."^^xsd:string ;
    uckb:whenToUse "High cognitive load, emergency action, or panic."^^xsd:string .

uckb:crisis_dispatch_005_safety_fact_elicitation a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Safety Fact Elicitation" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_triage_questioning ;
    uckb:ENHANCES uckb:Triage ;
    uckb:REQUIRES uckb:Grounding_where_overload_detected ;
    uckb:cardId "crisis_dispatch_005_safety_fact_elicitation"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-load"^^xsd:string ;
    uckb:contraindications "Do not interrogate trauma narrative beyond operational need."^^xsd:string ;
    uckb:culturalNotes "Explain purpose in high power-distance contexts to reduce fear."^^xsd:string ;
    uckb:description "Structured retrieval of minimum facts needed for emergency response."^^xsd:string ;
    uckb:dialogueActLinks "Question; Confirm; Inform"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Clinical triage questioning"^^xsd:string ;
    uckb:failureSignals "Caller feels interrogated or withdraws."^^xsd:string ;
    uckb:name "Safety Fact Elicitation"^^xsd:string ;
    uckb:requiredEdges "REQUIRES Grounding where overload detected; ENHANCES Triage"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Ask one fact; explain why; confirm; mark unknown if unavailable."^^xsd:string ;
    uckb:successSignals "Essential facts collected without escalation."^^xsd:string ;
    uckb:switchTo "Grounding; Active Listening"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "repair_request; hostility; silence_after_prompt"^^xsd:string ;
    uckb:whenNotToUse "Caller cannot answer due to panic before grounding."^^xsd:string ;
    uckb:whenToUse "Dispatcher needs location, immediate danger, injuries, weapons, or callback information."^^xsd:string .

uckb:crisis_dispatch_006_adult_state_boundary_setting a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Adult-State Boundary Setting" ;
    uckb:CONTRADICTS uckb:Mirrored_Aggression ;
    uckb:DOMAIN_VARIANT_OF uckb:Negotiation_boundary_setting ;
    uckb:TRIGGERED_BY uckb:Hostility ;
    uckb:cardId "crisis_dispatch_006_adult_state_boundary_setting"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-to-medium"^^xsd:string ;
    uckb:contraindications "Do not shame, punish, or threaten the caller."^^xsd:string ;
    uckb:culturalNotes "Use respectful authority framing in high power-distance contexts."^^xsd:string ;
    uckb:description "Neutral, firm boundary that prevents aggression from controlling the exchange."^^xsd:string ;
    uckb:dialogueActLinks "Directive; Inform; Repair"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Negotiation boundary setting"^^xsd:string ;
    uckb:failureSignals "Caller escalates or disengages."^^xsd:string ;
    uckb:name "Adult-State Boundary Setting"^^xsd:string ;
    uckb:requiredEdges "TRIGGERED_BY Hostility; CONTRADICTS Mirrored Aggression"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Validate concern; state boundary; redirect to safety fact; offer next step."^^xsd:string ;
    uckb:successSignals "Caller reduces interruption and answers task question."^^xsd:string ;
    uckb:switchTo "Empathic Validation; Safety Fact Elicitation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "volume_spike; absolutist_language; contempt_marker"^^xsd:string ;
    uckb:whenNotToUse "Caller is panicking and boundary would feel punitive."^^xsd:string ;
    uckb:whenToUse "Caller uses blame, threats, interruption, or abusive language."^^xsd:string .

uckb:crisis_dispatch_007_rapport_checkpoint a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Rapport Checkpoint" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_invitation_checkpoint ;
    uckb:FOLLOWS uckb:Empathic_Validation ;
    uckb:PRECEDES uckb:Influence_or_Proposal ;
    uckb:cardId "crisis_dispatch_007_rapport_checkpoint"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-load"^^xsd:string ;
    uckb:contraindications "Do not treat silence as consent."^^xsd:string ;
    uckb:culturalNotes "Silence may mean respect or processing, not agreement."^^xsd:string ;
    uckb:description "A brief confirmation that the caller is oriented enough for cooperation."^^xsd:string ;
    uckb:dialogueActLinks "Confirm; Accept; Feedback-Positive"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Clinical invitation checkpoint"^^xsd:string ;
    uckb:failureSignals "Caller resists or asks why."^^xsd:string ;
    uckb:name "Rapport Checkpoint"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Empathic Validation; PRECEDES Influence or Proposal"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Summarize; ask if caller can do the next step; wait for confirmation."^^xsd:string ;
    uckb:successSignals "Caller says yes, repeats plan, or complies."^^xsd:string ;
    uckb:switchTo "Active Listening; Transparency Statement"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "repair_request; low_trust"^^xsd:string ;
    uckb:whenNotToUse "Immediate danger requires instruction without conversational checkpoint."^^xsd:string ;
    uckb:whenToUse "Before moving from empathy to directive or proposal."^^xsd:string .

uckb:crisis_dispatch_008_transparency_statement a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Transparency Statement" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_informed_rationale ;
    uckb:ENHANCES uckb:Safety_Fact_Elicitation ;
    uckb:PRECEDES uckb:Sensitive_Question ;
    uckb:cardId "crisis_dispatch_008_transparency_statement"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "low-to-medium"^^xsd:string ;
    uckb:contraindications "Do not over-explain under high load."^^xsd:string ;
    uckb:culturalNotes "Use authority carefully; avoid bureaucratic tone."^^xsd:string ;
    uckb:description "Brief explanation of why a question or instruction is needed."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Request"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Clinical informed rationale"^^xsd:string ;
    uckb:failureSignals "Caller challenges motives or withholds information."^^xsd:string ;
    uckb:name "Transparency Statement"^^xsd:string ;
    uckb:requiredEdges "ENHANCES Safety Fact Elicitation; PRECEDES Sensitive Question"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Name purpose; ask or instruct; connect to caller benefit."^^xsd:string ;
    uckb:successSignals "Caller answers sensitive fact or follows instruction."^^xsd:string ;
    uckb:switchTo "One-Step Instruction; Empathic Validation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "low_trust; hostile_state"^^xsd:string ;
    uckb:whenNotToUse "Time-critical instruction where explanation would endanger safety."^^xsd:string ;
    uckb:whenToUse "Low trust, fear of consequences, or perceived interrogation."^^xsd:string .

uckb:crisis_dispatch_009_trauma_informed_validation a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Trauma-Informed Validation" ;
    uckb:CONTRAINDICATED_WHEN uckb:confrontational_probing ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_trauma-informed_language ;
    uckb:RESOLVES uckb:Shame_Escalation ;
    uckb:cardId "crisis_dispatch_009_trauma_informed_validation"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "lowest-load"^^xsd:string ;
    uckb:contraindications "Do not imply responsibility for harm."^^xsd:string ;
    uckb:culturalNotes "Preserve face and privacy in collectivist contexts."^^xsd:string ;
    uckb:description "Supportive response that avoids blame and protects agency after trauma cues."^^xsd:string ;
    uckb:dialogueActLinks "Acknowledge; Offer; Clarify"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Clinical trauma-informed language"^^xsd:string ;
    uckb:failureSignals "Caller freezes, dissociates, or self-blame intensifies."^^xsd:string ;
    uckb:name "Trauma-Informed Validation"^^xsd:string ;
    uckb:requiredEdges "CONTRAINDICATED_WHEN confrontational probing; RESOLVES Shame Escalation"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Affirm safety; avoid why questions; offer choice where possible."^^xsd:string ;
    uckb:successSignals "Caller continues narrative or accepts help."^^xsd:string ;
    uckb:switchTo "Grounding; Specialist Escalation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "self_blame; fragmented_narration"^^xsd:string ;
    uckb:whenNotToUse "Caller needs immediate medical or police instruction first."^^xsd:string ;
    uckb:whenToUse "Self-blame, fragmented memory, shame, fear of not being believed."^^xsd:string .

uckb:crisis_dispatch_010_specialist_escalation a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Specialist Escalation" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_escalation ;
    uckb:FOLLOWS uckb:Safety_Fact_Elicitation_where_possible ;
    uckb:TRIGGERED_BY uckb:High-Risk_Signal ;
    uckb:cardId "crisis_dispatch_010_specialist_escalation"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "lowest-load"^^xsd:string ;
    uckb:contraindications "Do not delay escalation to complete rapport sequence."^^xsd:string ;
    uckb:culturalNotes "Explain transfer respectfully to avoid abandonment perception."^^xsd:string ;
    uckb:description "Routing to human specialist, supervisor, clinician, or emergency resource when threshold met."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Directive; Confirm"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Clinical escalation"^^xsd:string ;
    uckb:failureSignals "Caller drops, refuses transfer, or risk rises."^^xsd:string ;
    uckb:name "Specialist Escalation"^^xsd:string ;
    uckb:requiredEdges "TRIGGERED_BY High-Risk Signal; FOLLOWS Safety Fact Elicitation where possible"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Identify threshold; keep caller engaged; transfer or dispatch; preserve context."^^xsd:string ;
    uckb:successSignals "Specialist connection established; caller remains oriented."^^xsd:string ;
    uckb:switchTo "Grounding; Stay-on-line Protocol"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "dissociation_risk; imminent_harm; psychosis_marker"^^xsd:string ;
    uckb:whenNotToUse "Issue can be resolved safely within normal dispatcher protocol."^^xsd:string ;
    uckb:whenToUse "Suicidality, psychosis, severe dissociation, imminent violence, medical emergency."^^xsd:string .

uckb:crisis_dispatch_011_calm_vocal_pacing a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Calm Vocal Pacing" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_crisis_variant,
        uckb:negotiation_de-escalation_variant ;
    uckb:PRECEDES uckb:higher-density_instruction ;
    uckb:REQUIRES uckb:safety_assessment ;
    uckb:cardId "crisis_dispatch_011_calm_vocal_pacing"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "lowest safe load"^^xsd:string ;
    uckb:contraindications "Do not use as a diagnostic label or as a reason to delay emergency response."^^xsd:string ;
    uckb:culturalNotes "Preserve dignity, privacy, and face; interpret silence cautiously."^^xsd:string ;
    uckb:description "Conscious modulation of speech rate, pitch, and rhythm to de-escalate arousal and model calm for the caller."^^xsd:string ;
    uckb:dialogueActLinks "Acknowledge; Clarify; Request; Inform; Confirm"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Clinical crisis variant; negotiation de-escalation variant"^^xsd:string ;
    uckb:failureSignals "Caller repeats distress, disengages, challenges the agent, or cannot follow the next step."^^xsd:string ;
    uckb:name "Calm Vocal Pacing"^^xsd:string ;
    uckb:requiredEdges "REQUIRES safety assessment; PRECEDES higher-density instruction"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S005; S006; S010"^^xsd:string ;
    uckb:steps "Slow own speech rate 20% below caller baseline; lower pitch one register; introduce deliberate pauses between phrases; maintain steady rhythm; mirror caller's pace downward toward calm."^^xsd:string ;
    uckb:successSignals "Caller remains engaged; essential facts become clearer; escalation does not increase."^^xsd:string ;
    uckb:switchTo "Grounding; One-Step Instruction; Specialist Escalation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "speech_rate_drop; speech_rate_spike; filler_increase; absolutist_language; volume_spike"^^xsd:string ;
    uckb:whenNotToUse "Do not use when a more urgent safety instruction, specialist escalation, or jurisdictional protocol takes precedence."^^xsd:string ;
    uckb:whenToUse "Use when the caller shows escalation, overload, uncertainty, risk, or a need for structured emergency support."^^xsd:string .

uckb:crisis_dispatch_012_location_confirmation a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Location Confirmation" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_crisis_variant,
        uckb:negotiation_de-escalation_variant ;
    uckb:PRECEDES uckb:higher-density_instruction ;
    uckb:REQUIRES uckb:safety_assessment ;
    uckb:cardId "crisis_dispatch_012_location_confirmation"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "lowest safe load"^^xsd:string ;
    uckb:contraindications "Do not use as a diagnostic label or as a reason to delay emergency response."^^xsd:string ;
    uckb:culturalNotes "Preserve dignity, privacy, and face; interpret silence cautiously."^^xsd:string ;
    uckb:description "Structured elicitation of the caller's exact physical location to enable accurate and timely dispatch."^^xsd:string ;
    uckb:dialogueActLinks "Acknowledge; Clarify; Request; Inform; Confirm"^^xsd:string ;
    uckb:domain "Crisis Dispatch / Emergency"^^xsd:string ;
    uckb:domainVariants "Clinical crisis variant; negotiation de-escalation variant"^^xsd:string ;
    uckb:failureSignals "Caller repeats distress, disengages, challenges the agent, or cannot follow the next step."^^xsd:string ;
    uckb:name "Location Confirmation"^^xsd:string ;
    uckb:requiredEdges "REQUIRES safety assessment; PRECEDES higher-density instruction"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
