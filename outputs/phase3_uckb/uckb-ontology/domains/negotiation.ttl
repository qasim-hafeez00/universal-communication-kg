    uckb:requiredEdges "FOLLOWS Teach; PRECEDES Take Control"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "Map insight to role; test fit; revise."^^xsd:string ;
    uckb:successSignals "Counterpart sees personal or organizational relevance."^^xsd:string ;
    uckb:switchTo "Stakeholder Mapping; Discovery"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "role_signal; objection"^^xsd:string ;
    uckb:whenNotToUse "Stakeholder context is unknown."^^xsd:string ;
    uckb:whenToUse "Commercial insight is accepted but relevance is unclear."^^xsd:string .

uckb:sales_and_negotiation_011_challenger_take_control a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Challenger Take Control" ;
    uckb:CONTRAINDICATED_WHEN uckb:distress_high ;
    uckb:DOMAIN_VARIANT_OF uckb:Crisis_influence_is_not_equivalent_and_must_be_blocked ;
