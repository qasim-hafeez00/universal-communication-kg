@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix uckb: <https://uckb.io/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

uckb:sales_and_negotiation_001_separate_people_from_problem a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Separate People From Problem" ;
    uckb:CONTRADICTS uckb:Personal_Attack ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_conflict_mediation ;
    uckb:PRECEDES uckb:Interest_Exploration ;
    uckb:cardId "sales_and_negotiation_001_separate_people_from_problem"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium"^^xsd:string ;
    uckb:contraindications "Do not use to minimize genuine harm."^^xsd:string ;
    uckb:culturalNotes "Face-saving phrasing is often needed in high-context settings."^^xsd:string ;
    uckb:description "Principled-negotiation technique that separates relational tension from substantive issue."^^xsd:string ;
    uckb:dialogueActLinks "Acknowledge; Clarify; Suggest"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical conflict mediation"^^xsd:string ;
    uckb:failureSignals "Personal blame continues; positions harden."^^xsd:string ;
    uckb:name "Separate People From Problem"^^xsd:string ;
    uckb:requiredEdges "PRECEDES Interest Exploration; CONTRADICTS Personal Attack"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "Name relationship concern; isolate issue; validate; return to merits."^^xsd:string ;
    uckb:successSignals "Lower defensiveness; clearer issue list."^^xsd:string ;
    uckb:switchTo "Empathic Validation; Objective Criteria"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "defensive_state; blame_language"^^xsd:string ;
    uckb:whenNotToUse "Pure emergency or clinical disclosure where negotiation framing is inappropriate."^^xsd:string ;
    uckb:whenToUse "Negotiation has conflict, defensiveness, or relationship preservation need."^^xsd:string .

uckb:sales_and_negotiation_002_interest_exploration a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Interest Exploration" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_values_elicitation ;
    uckb:FOLLOWS uckb:Separate_People_From_Problem ;
    uckb:PRECEDES uckb:Option_Generation ;
    uckb:cardId "sales_and_negotiation_002_interest_exploration"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium"^^xsd:string ;
    uckb:contraindications "Do not pressure disclosure of sensitive interests."^^xsd:string ;
    uckb:culturalNotes "Indirect interests may be expressed through stories."^^xsd:string ;
    uckb:description "Identifies underlying drivers behind stated positions."^^xsd:string ;
    uckb:dialogueActLinks "Question; Inform; Feedback"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical values elicitation"^^xsd:string ;
    uckb:failureSignals "Counterpart repeats position only."^^xsd:string ;
    uckb:name "Interest Exploration"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Separate People From Problem; PRECEDES Option Generation"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "Ask why/why not; summarize interests; separate from position."^^xsd:string ;
    uckb:successSignals "New motivations or constraints appear."^^xsd:string ;
    uckb:switchTo "Objective Criteria; Option Generation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "position_repetition; low_trust"^^xsd:string ;
    uckb:whenNotToUse "Counterpart is in crisis or lacks capacity for negotiation."^^xsd:string ;
    uckb:whenToUse "Counterpart repeats demands or rejects offers without clear reason."^^xsd:string .

uckb:sales_and_negotiation_003_option_generation a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Option Generation" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_shared_decision-making_variant ;
    uckb:PRECEDES uckb:Objective_Criteria ;
    uckb:REQUIRES uckb:Interest_Exploration ;
    uckb:cardId "sales_and_negotiation_003_option_generation"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium"^^xsd:string ;
    uckb:contraindications "Do not invent false choices."^^xsd:string ;
    uckb:culturalNotes "Offer options in culturally appropriate directness."^^xsd:string ;
    uckb:description "Creates multiple possible paths for mutual gain."^^xsd:string ;
    uckb:dialogueActLinks "Suggest; Offer; Accept-Suggestion"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical shared decision-making variant"^^xsd:string ;
    uckb:failureSignals "Options feel manipulative or irrelevant."^^xsd:string ;
    uckb:name "Option Generation"^^xsd:string ;
    uckb:requiredEdges "REQUIRES Interest Exploration; PRECEDES Objective Criteria"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "List options; test against interests; invite additions; defer judgment."^^xsd:string ;
    uckb:successSignals "Counterpart adds or ranks options."^^xsd:string ;
    uckb:switchTo "Tradeoff Framing; BATNA Clarification"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "collaborative_signal; objection"^^xsd:string ;
    uckb:whenNotToUse "Safety-critical or legal constraint permits only one action."^^xsd:string ;
    uckb:whenToUse "Interests are known but solution space is narrow."^^xsd:string .

uckb:sales_and_negotiation_004_objective_criteria a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Objective Criteria" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_evidence_explanation_variant ;
    uckb:ENHANCES uckb:Trust ;
    uckb:FOLLOWS uckb:Interest_Exploration ;
    uckb:cardId "sales_and_negotiation_004_objective_criteria"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium-to-high"^^xsd:string ;
    uckb:contraindications "Do not use pseudo-objective criteria."^^xsd:string ;
    uckb:culturalNotes "Authority standards may need explanation in low-trust settings."^^xsd:string ;
    uckb:description "Anchors agreement in independent standards rather than power or pressure."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Argue; Clarify"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical evidence explanation variant"^^xsd:string ;
    uckb:failureSignals "Counterpart disputes source or fairness."^^xsd:string ;
    uckb:name "Objective Criteria"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Interest Exploration; ENHANCES Trust"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "Name standard; show relevance; invite correction; apply consistently."^^xsd:string ;
    uckb:successSignals "Dispute shifts from identity to evidence."^^xsd:string ;
    uckb:switchTo "Source Transparency; Option Generation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "fairness_language; impasse"^^xsd:string ;
    uckb:whenNotToUse "No relevant standard exists or urgent human need outranks criteria."^^xsd:string ;
    uckb:whenToUse "Disagreement persists; trust is low; fairness is contested."^^xsd:string .

uckb:sales_and_negotiation_005_spin_situation_question a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "SPIN Situation Question" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_history-taking_analogue ;
    uckb:PRECEDES uckb:SPIN_Problem_Question ;
    uckb:cardId "sales_and_negotiation_005_spin_situation_question"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium"^^xsd:string ;
    uckb:contraindications "Do not ask obvious questions available from prior data."^^xsd:string ;
    uckb:culturalNotes "Explain purpose in high power-distance contexts."^^xsd:string ;
    uckb:description "Question that establishes current context without overloading the buyer."^^xsd:string ;
    uckb:dialogueActLinks "Question; Confirm"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical history-taking analogue"^^xsd:string ;
    uckb:failureSignals "Buyer perceives interrogation."^^xsd:string ;
    uckb:name "SPIN Situation Question"^^xsd:string ;
    uckb:requiredEdges "PRECEDES SPIN Problem Question"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "Ask concise situation question; confirm; move quickly to problem."^^xsd:string ;
    uckb:successSignals "Buyer gives usable context."^^xsd:string ;
    uckb:switchTo "Problem Question; Active Listening"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "low_context; discovery_phase"^^xsd:string ;
    uckb:whenNotToUse "Buyer is already overloaded or has provided sufficient context."^^xsd:string ;
    uckb:whenToUse "Early discovery and low shared context."^^xsd:string .

uckb:sales_and_negotiation_006_spin_problem_question a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "SPIN Problem Question" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_symptom-elicitation_analogue ;
    uckb:FOLLOWS uckb:Situation_Question ;
    uckb:PRECEDES uckb:Implication_Question ;
    uckb:cardId "sales_and_negotiation_006_spin_problem_question"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium"^^xsd:string ;
    uckb:contraindications "Do not manufacture pain."^^xsd:string ;
    uckb:culturalNotes "Use indirect phrasing where direct pain questions shame counterpart."^^xsd:string ;
    uckb:description "Question that surfaces pain, friction, or gap."^^xsd:string ;
    uckb:dialogueActLinks "Question; Inform"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical symptom-elicitation analogue"^^xsd:string ;
    uckb:failureSignals "Buyer denies or becomes defensive."^^xsd:string ;
    uckb:name "SPIN Problem Question"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Situation Question; PRECEDES Implication Question"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "Ask about difficulty; reflect; avoid leading."^^xsd:string ;
    uckb:successSignals "Buyer names problem in own words."^^xsd:string ;
    uckb:switchTo "Implication Question; Empathic Validation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "status_quo_bias; hesitation"^^xsd:string ;
    uckb:whenNotToUse "High defensiveness or trust too low."^^xsd:string ;
    uckb:whenToUse "Situation context exists and buyer is receptive."^^xsd:string .

uckb:sales_and_negotiation_007_spin_implication_question a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "SPIN Implication Question" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_risk_explanation_analogue ;
    uckb:PRECEDES uckb:Need-Payoff_Question ;
    uckb:REQUIRES uckb:Problem_Question ;
    uckb:cardId "sales_and_negotiation_007_spin_implication_question"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium-to-high"^^xsd:string ;
    uckb:contraindications "Avoid manipulation or inflated risk."^^xsd:string ;
    uckb:culturalNotes "Frame implications respectfully, not as threat."^^xsd:string ;
    uckb:description "Question that explores consequences of an unresolved problem."^^xsd:string ;
    uckb:dialogueActLinks "Question; Suggest"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical risk explanation analogue"^^xsd:string ;
    uckb:failureSignals "Buyer feels fear-based pressure."^^xsd:string ;
    uckb:name "SPIN Implication Question"^^xsd:string ;
    uckb:requiredEdges "REQUIRES Problem Question; PRECEDES Need-Payoff Question"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "Ask consequence question; quantify where possible; validate burden."^^xsd:string ;
    uckb:successSignals "Buyer articulates cost of inaction."^^xsd:string ;
    uckb:switchTo "Need-Payoff; Objective Criteria"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "status_quo_bias; cost_signal"^^xsd:string ;
    uckb:whenNotToUse "Problem is emotionally sensitive and rapport is weak."^^xsd:string ;
    uckb:whenToUse "Buyer recognizes problem but not urgency."^^xsd:string .

uckb:sales_and_negotiation_008_spin_need_payoff_question a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "SPIN Need-Payoff Question" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_goal-setting_analogue ;
    uckb:ENHANCES uckb:Commitment ;
    uckb:FOLLOWS uckb:Implication_Question ;
    uckb:cardId "sales_and_negotiation_008_spin_need_payoff_question"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium"^^xsd:string ;
    uckb:contraindications "Do not script the buyer's answer."^^xsd:string ;
    uckb:culturalNotes "Group benefit may matter more than individual benefit."^^xsd:string ;
    uckb:description "Question that helps counterpart describe value of improvement."^^xsd:string ;
    uckb:dialogueActLinks "Question; Accept-Suggestion"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical goal-setting analogue"^^xsd:string ;
    uckb:failureSignals "Buyer gives performative agreement only."^^xsd:string ;
    uckb:name "SPIN Need-Payoff Question"^^xsd:string ;
    uckb:requiredEdges "FOLLOWS Implication Question; ENHANCES Commitment"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "Ask future-state value; summarize; invite evaluation."^^xsd:string ;
    uckb:successSignals "Buyer states benefit in own terms."^^xsd:string ;
    uckb:switchTo "Proposal; Option Generation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "buying_signal; receptive_state"^^xsd:string ;
    uckb:whenNotToUse "Buyer is not ready or feels coerced."^^xsd:string ;
    uckb:whenToUse "Problem and implications are accepted."^^xsd:string .

uckb:sales_and_negotiation_009_challenger_teach a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Challenger Teach" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_education_analogue ;
    uckb:PRECEDES uckb:Tailor ;
    uckb:REQUIRES uckb:Source_Transparency ;
    uckb:cardId "sales_and_negotiation_009_challenger_teach"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "high"^^xsd:string ;
    uckb:contraindications "Do not use weak insight as authority performance."^^xsd:string ;
    uckb:culturalNotes "Adapt directness to status and face concerns."^^xsd:string ;
    uckb:description "Provides a useful commercial insight that reframes the buyer's understanding."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Argue; Suggest"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical education analogue"^^xsd:string ;
    uckb:failureSignals "Buyer challenges credibility."^^xsd:string ;
    uckb:name "Challenger Teach"^^xsd:string ;
    uckb:requiredEdges "REQUIRES Source Transparency; PRECEDES Tailor"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "State insight; support with evidence; connect to buyer context."^^xsd:string ;
    uckb:successSignals "Buyer asks deeper question or revises assumption."^^xsd:string ;
    uckb:switchTo "Tailor; Objective Criteria"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "status_quo_bias; analytical_style"^^xsd:string ;
    uckb:whenNotToUse "Trust is too low or data is weak."^^xsd:string ;
    uckb:whenToUse "Buyer has entrenched assumptions or missed risk."^^xsd:string .

uckb:sales_and_negotiation_010_challenger_tailor a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Challenger Tailor" ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_personalization_analogue ;
    uckb:FOLLOWS uckb:Teach ;
    uckb:PRECEDES uckb:Take_Control ;
    uckb:cardId "sales_and_negotiation_010_challenger_tailor"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium-to-high"^^xsd:string ;
    uckb:contraindications "Do not over-personalize from weak data."^^xsd:string ;
    uckb:culturalNotes "Avoid assumptions about hierarchy or decision authority."^^xsd:string ;
    uckb:description "Adapts insight to role, industry, and stakeholder priority."^^xsd:string ;
    uckb:dialogueActLinks "Inform; Clarify"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical personalization analogue"^^xsd:string ;
    uckb:failureSignals "Counterpart says not relevant."^^xsd:string ;
