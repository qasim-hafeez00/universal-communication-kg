    uckb:requiredEdges "REQUIRES Rapport; CONTRAINDICATED_WHEN distress high"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "Name next decision; offer path; ask for commitment."^^xsd:string ;
    uckb:successSignals "Buyer agrees to next step."^^xsd:string ;
    uckb:switchTo "MEDDIC Next Step; Objection Handling"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "stalling; low_trust"^^xsd:string ;
    uckb:whenNotToUse "Emotional trust or rapport is missing."^^xsd:string ;
