uckb:sales_and_negotiation_012_batna_clarification a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "BATNA Clarification" ;
    uckb:CONTRAINDICATED_WHEN uckb:high_distress ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_shared_decision-making_analogue,
        uckb:crisis_use_blocked_unless_safety_justified ;
    uckb:ENHANCES uckb:Discovery ;
    uckb:REQUIRES uckb:Rapport ;
    uckb:cardId "sales_and_negotiation_012_batna_clarification"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium unless overload signals require simplification"^^xsd:string ;
    uckb:contraindications "Do not use manipulative pressure, false scarcity, or unsupported authority."^^xsd:string ;
    uckb:culturalNotes "Adapt directness, hierarchy, and face-saving to cultural context."^^xsd:string ;
    uckb:description "Identification and assessment of the Best Alternative to a Negotiated Agreement, used to establish the walk-away threshold for any party."^^xsd:string ;
    uckb:dialogueActLinks "Question; Suggest; Inform; Offer; Accept-Suggestion"^^xsd:string ;
    uckb:domain "Sales & Negotiation"^^xsd:string ;
    uckb:domainVariants "Clinical shared decision-making analogue; crisis use blocked unless safety justified"^^xsd:string ;
    uckb:failureSignals "Counterpart perceives pressure, withdraws, or repeats the same objection."^^xsd:string ;
    uckb:name "BATNA Clarification"^^xsd:string ;
    uckb:requiredEdges "REQUIRES Rapport; ENHANCES Discovery; CONTRAINDICATED_WHEN high distress"^^xsd:string ;
    uckb:reviewNotes "Seed card; requires domain expert review before Phase 3 ingestion."^^xsd:string ;
    uckb:reviewStatus "source_checked"^^xsd:string ;
    uckb:sourceIds "S001; S002; S003; S007; S008; S010"^^xsd:string ;
    uckb:steps "Identify your own Best Alternative to a Negotiated Agreement before the session; estimate the other party's BATNA from available information; set your walk-away threshold at or above your BATNA value; do not reveal your BATNA; use it as a confidence anchor throughout."^^xsd:string ;
    uckb:successSignals "Counterpart clarifies interests, constraints, buying process, or next action."^^xsd:string ;
    uckb:switchTo "Interest Exploration; Objective Criteria; Empathic Validation"^^xsd:string ;
    uckb:tier "Tier 1"^^xsd:string ;
    uckb:triggerSignals "objection; status_quo_bias; low_trust; analytical_style; buying_signal"^^xsd:string ;
    uckb:whenNotToUse "Do not use during crisis, clinical vulnerability, or when the counterpart lacks capacity or consent."^^xsd:string ;
    uckb:whenToUse "Use when the counterpart is commercially engaged and the relationship can support structured discovery or negotiation."^^xsd:string .

uckb:sales_and_negotiation_013_zopa_mapping a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "ZOPA Mapping" ;
    uckb:CONTRAINDICATED_WHEN uckb:high_distress ;
    uckb:DOMAIN_VARIANT_OF uckb:Clinical_shared_decision-making_analogue,
        uckb:crisis_use_blocked_unless_safety_justified ;
    uckb:ENHANCES uckb:Discovery ;
    uckb:REQUIRES uckb:Rapport ;
    uckb:cardId "sales_and_negotiation_013_zopa_mapping"^^xsd:string ;
    uckb:classLabel "CommunicationTechnique"^^xsd:string ;
    uckb:cognitiveLoadProfile "medium unless overload signals require simplification"^^xsd:string ;
    uckb:contraindications "Do not use manipulative pressure, false scarcity, or unsupported authority."^^xsd:string ;
    uckb:culturalNotes "Adapt directness, hierarchy, and face-saving to cultural context."^^xsd:string ;
