        "@value": "high"
      }
    ],
    "https://uckb.io/ontology#cardId": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "clinical_045_clinical_panic_state"
      }
    ],
    "https://uckb.io/ontology#classLabel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EmotionalState"
      }
    ],
    "https://uckb.io/ontology#cognitiveLoadProfile": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "low-to-medium; lower when distress or confusion appears"
      }
    ],
    "https://uckb.io/ontology#contraindications": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Do not replace licensed clinical judgment, emergency protocol, or consent requirements."
      }
    ],
    "https://uckb.io/ontology#culturalNotes": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Respect family roles, privacy, face-saving, and interpreter needs with patient consent."
      }
    ],
    "https://uckb.io/ontology#description": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Detection of acute panic response in a patient, triggering suspension of information delivery and initiation of grounding protocols."
      }
    ],
    "https://uckb.io/ontology#dialogueActLinks": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Inform; Question; Acknowledge; Confirm; Suggest"
      }
    ],
    "https://uckb.io/ontology#domain": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Clinical / Medical"
      }
    ],
    "https://uckb.io/ontology#domainVariants": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Crisis dispatch health instruction; sales shared-decision analogue"
      }
    ],
    "https://uckb.io/ontology#failureSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Patient shows confusion, shame, withdrawal, repeated repair requests, or unsafe plan interpretation."
      }
    ],
    "https://uckb.io/ontology#name": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Clinical Panic State"
      }
    ],
    "https://uckb.io/ontology#requiredEdges": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "REQUIRES Consent Checkpoint where sensitive; ENHANCES Teach-Back; CONTRAINDICATED_WHEN acute instability"
      }
    ],
    "https://uckb.io/ontology#reviewNotes": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Seed card; requires domain expert review before Phase 3 ingestion."
      }
    ],
    "https://uckb.io/ontology#reviewStatus": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "source_checked"
      }
    ],
    "https://uckb.io/ontology#sourceIds": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "S001; S002; S003; S009; S010"
      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Detect acute panic via very short utterances, rapid breathing, incoherent or repetitive questions; stop all information delivery immediately; initiate grounding: slow breathing, one orienting question; maintain slow calm pacing; do not resume clinical content until panic has subsided."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Patient can explain the issue, options, risks, and next action in their own words."
      }
    ],
    "https://uckb.io/ontology#switchTo": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Teach-Back; SPIKES Emotion; Follow-Up Safety Net"
      }
    ],
    "https://uckb.io/ontology#tier": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Tier 1"
      }
    ],
    "https://uckb.io/ontology#triggerSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "repair_request; silence_after_prompt; grief_marker; medical_jargon_confusion; teach_back_failure"
      }
    ],
    "https://uckb.io/ontology#valence": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "negative"
      }
    ],
    "https://uckb.io/ontology#whenNotToUse": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Do not use when emergency intervention, specialist escalation, or local clinical protocol overrides conversational sequencing."
      }
    ],
    "https://uckb.io/ontology#whenToUse": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Use when clinical information, behavior change, uncertainty, emotion, or comprehension risk must be managed."
      }
    ]
  },
  {
