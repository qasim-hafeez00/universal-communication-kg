    "https://uckb.io/ontology#cognitiveLoadProfile": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "low"
      }
    ],
    "https://uckb.io/ontology#contraindications": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Never frame as testing patient intelligence."
      }
    ],
    "https://uckb.io/ontology#culturalNotes": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Use humble clinician framing."
      }
    ],
    "https://uckb.io/ontology#description": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Asks patient to explain plan in their own words to verify comprehension."
      }
    ],
    "https://uckb.io/ontology#dialogueActLinks": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Check-Question; Inform; Confirm"
      }
    ],
