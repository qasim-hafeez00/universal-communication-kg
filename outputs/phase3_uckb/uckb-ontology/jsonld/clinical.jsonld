      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Acknowledge what is not yet known about the diagnosis or prognosis; state your current best understanding clearly; distinguish it explicitly from confirmed knowledge; offer a plan for obtaining missing information."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Patient can explain the issue, options, risks, and next action in their own words."
