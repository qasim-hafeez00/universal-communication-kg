      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "State relative risk and immediately anchor it to an absolute baseline; example: 'This doubles the risk — going from 1 in 1000 to 2 in 1000'; always provide both relative and absolute figures together; confirm the patient understood the absolute, not just the relative, figure."
      }
