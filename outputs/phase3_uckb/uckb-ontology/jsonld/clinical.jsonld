        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Ask: 'Do you prefer to discuss your care in a language other than English?'; offer a trained interpreter before beginning any sensitive clinical topic; do not use family members as interpreters by default; document language preference."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Patient can explain the issue, options, risks, and next action in their own words."
      }
    ],
    "https://uckb.io/ontology#switchTo": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Teach-Back; SPIKES Emotion; Follow-Up Safety Net"
      }
    ],
    "https://uckb.io/ontology#tier": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Tier 1"
      }
    ],
    "https://uckb.io/ontology#triggerSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "repair_request; silence_after_prompt; grief_marker; medical_jargon_confusion; teach_back_failure"
      }
    ],
    "https://uckb.io/ontology#whenNotToUse": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Do not use when emergency intervention, specialist escalation, or local clinical protocol overrides conversational sequencing."
      }
    ],
    "https://uckb.io/ontology#whenToUse": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
