      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Allow the anger to be fully expressed without interruption or defense; name the anger specifically: 'It sounds like you are furious about this'; validate it as an understandable response; do not defend the diagnosis or the clinical team; re-engage only when the acute affect has subsided."
      }
    ],
