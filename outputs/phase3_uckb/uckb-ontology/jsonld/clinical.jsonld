      }
    ],
    "https://uckb.io/ontology#requiredEdges": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "REQUIRES Consent Checkpoint where sensitive; ENHANCES Teach-Back; CONTRAINDICATED_WHEN acute instability"
      }
    ],
    "https://uckb.io/ontology#reviewNotes": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Seed card; requires domain expert review before Phase 3 ingestion."
      }
    ],
