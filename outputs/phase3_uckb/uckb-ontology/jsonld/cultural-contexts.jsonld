    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Close physical and conversational space is normal; distance signals rejection."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "High Proxemics"
      }
    ]
  },
  {
