    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Detect short, disjointed, incomplete utterances; slow own pace in response; ask one orienting question ('Where are you right now?'); tolerate incomplete answers; piece together the situation from fragments without rushing."
      }
    ],
