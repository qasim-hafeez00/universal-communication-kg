      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Offer an indirect framing that allows the caller to comply without losing face; avoid forcing a direct contradiction or admission; provide a face-saving exit: 'Many people in this situation find it helpful to…'; wait for response without pressing."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
      {
