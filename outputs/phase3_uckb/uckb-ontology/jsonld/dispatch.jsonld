      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Detect ideation signals: statements of hopelessness, farewell language, giving-things-away references; do not challenge or argue against the ideation; express the value of the caller's life specifically; ask directly: 'Are you thinking about ending your life?'; escalate to specialist or emergency services immediately."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
