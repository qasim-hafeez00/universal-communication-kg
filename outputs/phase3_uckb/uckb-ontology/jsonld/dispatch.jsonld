      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Say: 'I need to ask you a few questions to get help to you as quickly as possible — is that okay?'; wait for a yes or equivalent; acknowledge any hesitation; begin with the least sensitive question first."
      }
    ],
