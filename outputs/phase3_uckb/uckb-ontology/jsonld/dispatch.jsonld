      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Slow own speech rate 20% below caller baseline; lower pitch one register; introduce deliberate pauses between phrases; maintain steady rhythm; mirror caller's pace downward toward calm."
      }
    ],
