      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "source_checked"
      }
    ],
    "https://uckb.io/ontology#sourceIds": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "S001; S002; S003; S005; S006; S010"
      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Detect over-nurturing toward another party: excessive worry, over-control; validate the care; separate the caller's own safety from the other person's; guide toward practical action rather than total control."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Caller remains engaged; essential facts become clearer; escalation does not increase."
      }
    ],
    "https://uckb.io/ontology#switchTo": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Grounding; One-Step Instruction; Specialist Escalation"
      }
    ],
    "https://uckb.io/ontology#tier": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Tier 1"
      }
    ],
    "https://uckb.io/ontology#triggerSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "speech_rate_drop; speech_rate_spike; filler_increase; absolutist_language; volume_spike"
      }
    ],
    "https://uckb.io/ontology#whenNotToUse": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Do not use when a more urgent safety instruction, specialist escalation, or jurisdictional protocol takes precedence."
      }
    ],
    "https://uckb.io/ontology#whenToUse": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Use when the caller shows escalation, overload, uncertainty, risk, or a need for structured emergency support."
      }
    ]
  },
