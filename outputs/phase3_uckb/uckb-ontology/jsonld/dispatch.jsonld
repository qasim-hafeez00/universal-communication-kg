        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Slow all communication to half the standard cadence; allow extended pauses after each utterance; do not move to operational questions until grief affect subsides; validate the loss before any information gathering."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Caller remains engaged; essential facts become clearer; escalation does not increase."
      }
    ],
