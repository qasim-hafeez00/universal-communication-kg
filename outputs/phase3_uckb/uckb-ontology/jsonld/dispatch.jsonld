      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Detect flat affect, vague repetitive responses, and unresponsiveness to questions; avoid complex multi-step queries; use gentle orienting prompts: 'Can you tell me what you see right now?'; consider specialist escalation if dissociation is suspected."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Caller remains engaged; essential facts become clearer; escalation does not increase."
      }
    ],
