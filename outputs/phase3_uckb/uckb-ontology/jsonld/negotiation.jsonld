      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Lead with the recommendation and its business impact; state the supporting case in three bullet points maximum; quantify the projected impact; include the cost of inaction; keep to one page in writing or 90 seconds verbally."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
