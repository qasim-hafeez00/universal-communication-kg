    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Present only the solution elements that map to the specific pains uncovered in discovery; do not demonstrate features that were not requested or that solve no stated pain; link each element explicitly to a stated criterion or pain; check for alignment after each element."
      }
