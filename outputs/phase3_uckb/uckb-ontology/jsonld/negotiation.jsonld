      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Identify the most significant loss the buyer faces by not acting; frame the value proposition around that loss specifically; use concrete examples tied to the buyer's context; avoid gain-framing until loss-framing is established."
      }
    ],
