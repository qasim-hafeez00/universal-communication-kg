      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Do not use during crisis, clinical vulnerability, or when the counterpart lacks capacity or consent."
      }
    ],
    "https://uckb.io/ontology#whenToUse": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
