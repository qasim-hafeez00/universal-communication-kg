        "@value": "S001; S002; S003; S007; S008; S010"
      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Ask directly: 'If this meets your criteria, are you in a position to decide?'; clarify exactly who has decision authority; confirm the full decision process; do not invest in a full proposal for a non-buyer."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Counterpart clarifies interests, constraints, buying process, or next action."
      }
    ],
