      }
    ],
    "https://uckb.io/ontology#steps": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "State the answer or recommendation at the very beginning; then provide the supporting logical argument; then provide the detailed evidence; never bury the main point mid-document or mid-conversation."
      }
