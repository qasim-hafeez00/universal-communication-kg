        "@value": "Identify your own Best Alternative to a Negotiated Agreement before the session; estimate the other party's BATNA from available information; set your walk-away threshold at or above your BATNA value; do not reveal your BATNA; use it as a confidence anchor throughout."
      }
    ],
    "https://uckb.io/ontology#successSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Counterpart clarifies interests, constraints, buying process, or next action."
      }
    ],
    "https://uckb.io/ontology#switchTo": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Interest Exploration; Objective Criteria; Empathic Validation"
      }
    ],
    "https://uckb.io/ontology#tier": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Tier 1"
      }
    ],
    "https://uckb.io/ontology#triggerSignals": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "objection; status_quo_bias; low_trust; analytical_style; buying_signal"
      }
    ],
    "https://uckb.io/ontology#whenNotToUse": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Do not use during crisis, clinical vulnerability, or when the counterpart lacks capacity or consent."
      }
    ],
    "https://uckb.io/ontology#whenToUse": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Use when the counterpart is commercially engaged and the relationship can support structured discovery or negotiation."
      }
    ]
