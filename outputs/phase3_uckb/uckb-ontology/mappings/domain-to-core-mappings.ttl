uckb:TraumaInformedGrounding a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:Grounding .

uckb:ConflictDeEscalation a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Conflict De-escalation" ;
    rdfs:comment "Core de-escalation framework." .

uckb:InformationGathering a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Information Gathering" ;
    rdfs:comment "Core structured elicitation framework." .

uckb:Negotiation a owl:NamedIndividual,
        uckb:DomainProtocol ;
    rdfs:label "Negotiation" ;
    rdfs:comment "Core negotiation framework." .

uckb:Rapport a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Rapport" ;
    rdfs:comment "Core rapport-building framework." .

uckb:Grounding a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Grounding" ;
    rdfs:comment "Core present-focus grounding framework." .

uckb:ActiveListening a owl:NamedIndividual,
