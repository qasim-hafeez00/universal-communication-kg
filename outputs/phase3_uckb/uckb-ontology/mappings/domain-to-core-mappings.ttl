@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix uckb: <https://uckb.io/ontology#> .

uckb:ChallengerInsight a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:NeedsAssessment .

uckb:ClinicalEmpathy a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:EmpathicValidation .

uckb:ClinicalGrounding a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:Grounding .

