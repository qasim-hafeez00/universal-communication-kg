    rdfs:comment "Core MI protocol for ambivalence resolution." .

uckb:MotivationalListening a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:ActiveListening .

uckb:NegotiationRapport a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:Rapport .

uckb:ReflectiveListening a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:ActiveListening .

uckb:SOLER a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:ActiveListening .

uckb:SPIKES_SupportStep a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:EmpathicValidation .

uckb:SPIN_Selling a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:NeedsAssessment .

uckb:SafetyPlanning a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:ConflictDeEscalation .

uckb:SalesEmpathy a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:EmpathicValidation .

uckb:SandlerPainFunnel a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:NeedsAssessment .

uckb:TacticalEmpathy a owl:NamedIndividual ;
