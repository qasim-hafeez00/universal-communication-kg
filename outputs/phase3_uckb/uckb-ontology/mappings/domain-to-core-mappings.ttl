uckb:CrisisEmpathy a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:EmpathicValidation .

uckb:Empathy a owl:NamedIndividual,
        uckb:CommunicationTechnique ;
    rdfs:label "Empathy" ;
    rdfs:comment "Core empathy expression framework." .

uckb:HarvardPrincipledNeg a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:Negotiation .

uckb:MEDDIC_Qualification a owl:NamedIndividual ;
    uckb:DOMAIN_VARIANT_OF uckb:NeedsAssessment .

uckb:MotivationalInterviewing a owl:NamedIndividual,
