@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix iso: <https://uckb.io/ontology/iso24617#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix uckb: <https://uckb.io/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

uckb:belongsToDimension a owl:ObjectProperty ;
    rdfs:label "belongs to dimension"@en ;
    rdfs:domain uckb:DialogueAct ;
    rdfs:range uckb:DialogueDimension .

uckb:certainty a owl:DatatypeProperty ;
    rdfs:label "certainty qualifier"@en ;
    rdfs:range xsd:string .

uckb:communicativeFunction a owl:DatatypeProperty ;
    rdfs:label "communicative function"@en ;
    rdfs:range xsd:string .

uckb:conditionality a owl:DatatypeProperty ;
    rdfs:label "conditionality qualifier"@en ;
    rdfs:range xsd:string .

uckb:dependencyType a owl:DatatypeProperty ;
    rdfs:label "functional dependency type (responds-to|initiates)"@en ;
    rdfs:range xsd:string .

uckb:dimension a owl:DatatypeProperty ;
    rdfs:label "ISO 24617-2 dimension name"@en ;
    rdfs:range xsd:string .

uckb:functionalDependency a owl:ObjectProperty ;
    rdfs:label "functional dependency"@en ;
    rdfs:domain uckb:DialogueAct ;
    rdfs:range uckb:DialogueAct .

uckb:requiresGrounding a owl:DatatypeProperty ;
    rdfs:label "requires grounding act first"@en ;
    rdfs:range xsd:boolean .

uckb:requiresInfluencePrereq a owl:DatatypeProperty ;
    rdfs:label "requires empathy/rapport prerequisite"@en ;
    rdfs:range xsd:boolean .

uckb:sentiment a owl:DatatypeProperty ;
    rdfs:label "sentiment qualifier"@en ;
    rdfs:range xsd:string .

uckb:typicalSender a owl:DatatypeProperty ;
    rdfs:label "typical sender role"@en ;
    rdfs:range xsd:string .

iso:da_accept_proposal a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "AcceptProposal"@en ;
    rdfs:comment "Speaker accepts a previously proposed course of action."@en ;
    uckb:belongsToDimension iso:dim_task ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "AcceptProposal" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "task" ;
    uckb:functionalDependency iso:dep_da_accept_proposal_da_proposal ;
    uckb:id "da_accept_proposal" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "positive" ;
    uckb:typicalSender "Either" .

iso:da_agreement a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Agreement"@en ;
    rdfs:comment "Speaker commits to or aligns with a proposition or proposal."@en ;
    uckb:belongsToDimension iso:dim_task ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "Agreement" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "task" ;
    uckb:functionalDependency iso:dep_da_agreement_da_proposal ;
    uckb:id "da_agreement" ;
    uckb:requiresGrounding true ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "positive" ;
    uckb:typicalSender "Either" .

iso:da_allo_negative a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "AlloNegative"@en ;
    rdfs:comment "Speaker evaluates the preceding act as inadequate or incorrect."@en ;
    uckb:belongsToDimension iso:dim_feedback ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "AlloNegative" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "feedback" ;
    uckb:functionalDependency iso:dep_da_allo_negative_da_request ;
    uckb:id "da_allo_negative" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "negative" ;
    uckb:typicalSender "Either" .

iso:da_allo_positive a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "AlloPositive"@en ;
    rdfs:comment "Speaker evaluates the preceding act as adequate or correct."@en ;
    uckb:belongsToDimension iso:dim_feedback ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "AlloPositive" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "feedback" ;
    uckb:functionalDependency iso:dep_da_allo_positive_da_request ;
    uckb:id "da_allo_positive" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "positive" ;
    uckb:typicalSender "Either" .

iso:da_answer a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Answer"@en ;
    rdfs:comment "Speaker provides information in direct response to a prior Request."@en ;
    uckb:belongsToDimension iso:dim_task ;
    uckb:certainty "uncertain" ;
    uckb:communicativeFunction "Answer" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "task" ;
    uckb:functionalDependency iso:dep_da_answer_da_request ;
    uckb:id "da_answer" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Either" .

iso:da_apology a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Apology"@en ;
    rdfs:comment "Speaker expresses regret for a prior act that affected the addressee negatively."@en ;
    uckb:belongsToDimension iso:dim_social ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "Apology" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "social" ;
    uckb:id "da_apology" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "negative" ;
    uckb:typicalSender "Either" .

iso:da_approval a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Approval"@en ;
    rdfs:comment "Speaker expresses positive evaluation of the addressee's action or statement."@en ;
    uckb:belongsToDimension iso:dim_social ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "Approval" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "social" ;
    uckb:id "da_approval" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "positive" ;
    uckb:typicalSender "Agent" .

iso:da_auto_negative a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "AutoNegative"@en ;
    rdfs:comment "Speaker signals they have not understood or need clarification."@en ;
    uckb:belongsToDimension iso:dim_feedback ;
    uckb:certainty "uncertain" ;
    uckb:communicativeFunction "AutoNegative" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "feedback" ;
    uckb:functionalDependency iso:dep_da_auto_negative_da_inform ;
    uckb:id "da_auto_negative" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "negative" ;
    uckb:typicalSender "Either" .

iso:da_auto_positive a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "AutoPositive"@en ;
    rdfs:comment "Speaker signals they have understood the preceding utterance (e.g., 'uh-huh', 'okay')."@en ;
    uckb:belongsToDimension iso:dim_feedback ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "AutoPositive" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "feedback" ;
    uckb:functionalDependency iso:dep_da_auto_positive_da_inform ;
