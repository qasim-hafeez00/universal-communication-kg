    uckb:id "da_indicate_understanding" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "positive" ;
    uckb:typicalSender "Agent" .

iso:da_interrupt a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Interrupt"@en ;
    rdfs:comment "Speaker takes the floor while the addressee is still speaking."@en ;
    uckb:belongsToDimension iso:dim_turn_taking ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "Interrupt" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "turntaking" ;
    uckb:id "da_interrupt" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "negative" ;
    uckb:typicalSender "Either" .

iso:da_reformulation a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Reformulation"@en ;
    rdfs:comment "Speaker restates their own prior utterance with different wording for clarity."@en ;
    uckb:belongsToDimension iso:dim_own_comm ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "Reformulation" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "owncomm" ;
    uckb:id "da_reformulation" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Either" .

iso:da_request_repair a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "RequestRepair"@en ;
    rdfs:comment "Speaker asks the addressee to repair or clarify a problematic utterance."@en ;
    uckb:belongsToDimension iso:dim_partner_comm ;
    uckb:certainty "uncertain" ;
    uckb:communicativeFunction "RequestRepair" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "partnercomm" ;
    uckb:functionalDependency iso:dep_da_request_repair_da_inform ;
    uckb:id "da_request_repair" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Either" .

iso:da_retraction a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Retraction"@en ;
    rdfs:comment "Speaker withdraws a previously made commitment or assertion."@en ;
    uckb:belongsToDimension iso:dim_own_comm ;
    uckb:certainty "uncertain" ;
    uckb:communicativeFunction "Retraction" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "owncomm" ;
    uckb:id "da_retraction" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Either" .

iso:da_self_correction a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "SelfCorrection"@en ;
    rdfs:comment "Speaker repairs their own preceding utterance."@en ;
    uckb:belongsToDimension iso:dim_own_comm ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "SelfCorrection" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "owncomm" ;
    uckb:id "da_self_correction" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Either" .

iso:da_stalling a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Stalling"@en ;
    rdfs:comment "Speaker uses fillers or delays to hold the floor while processing (e.g., 'um', 'well...')."@en ;
    uckb:belongsToDimension iso:dim_own_comm ;
    uckb:certainty "uncertain" ;
    uckb:communicativeFunction "Stalling" ;
    uckb:conditionality "unconditional" ;
