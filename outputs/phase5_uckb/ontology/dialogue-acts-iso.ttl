    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "positive" ;
    uckb:typicalSender "Agent" .

iso:da_goodbye a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Goodbye"@en ;
    rdfs:comment "Conventional closing act terminating social contact."@en ;
