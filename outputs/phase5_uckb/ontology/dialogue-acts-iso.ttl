    uckb:typicalSender "Either" .

iso:da_contact_check a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "ContactCheck"@en ;
    rdfs:comment "Speaker verifies that the communication channel is open (e.g., 'Are you still there?')."@en ;
    uckb:belongsToDimension iso:dim_feedback ;
