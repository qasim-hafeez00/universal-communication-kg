    rdfs:label "ClarificationRequest"@en ;
    rdfs:comment "Speaker asks the addressee to elaborate or clarify a specific aspect of their utterance."@en ;
    uckb:belongsToDimension iso:dim_partner_comm ;
    uckb:certainty "uncertain" ;
    uckb:communicativeFunction "ClarificationRequest" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "partnercomm" ;
    uckb:functionalDependency iso:dep_da_clarification_request_da_inform ;
    uckb:id "da_clarification_request" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Either" .

iso:da_confirm a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Confirm"@en ;
    rdfs:comment "Speaker verifies or reaffirms a proposition previously asserted."@en ;
    uckb:belongsToDimension iso:dim_task ;
    uckb:certainty "certain" ;
