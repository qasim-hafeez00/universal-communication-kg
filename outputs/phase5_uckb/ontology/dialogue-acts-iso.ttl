    uckb:conditionality "unconditional" ;
    uckb:dimension "feedback" ;
    uckb:id "da_contact_check" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Agent" .

iso:da_correction a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Correction"@en ;
