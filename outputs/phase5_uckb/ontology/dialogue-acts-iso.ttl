    uckb:conditionality "unconditional" ;
    uckb:dimension "social" ;
    uckb:functionalDependency iso:dep_da_farewell_da_goodbye ;
    uckb:id "da_farewell" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "positive" ;
    uckb:typicalSender "Either" .

iso:da_give_turn a owl:NamedIndividual,
