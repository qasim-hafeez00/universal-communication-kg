    uckb:belongsToDimension iso:dim_task ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "Disagreement" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "task" ;
    uckb:functionalDependency iso:dep_da_disagreement_da_proposal ;
