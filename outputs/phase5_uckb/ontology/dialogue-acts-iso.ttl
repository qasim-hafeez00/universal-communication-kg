    uckb:typicalSender "Either" .

iso:da_offer_turn a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "OfferTurn"@en ;
    rdfs:comment "Speaker explicitly offers the speaking turn to the addressee."@en ;
    uckb:belongsToDimension iso:dim_turn_taking ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "OfferTurn" ;
