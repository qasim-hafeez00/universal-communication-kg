iso:da_welcome a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Welcome"@en ;
    rdfs:comment "Speaker accepts the addressee's thanks, indicating the prior act was not burdensome."@en ;
    uckb:belongsToDimension iso:dim_social ;
