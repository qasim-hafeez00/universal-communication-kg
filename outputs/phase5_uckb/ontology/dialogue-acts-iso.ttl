iso:da_indicate_understanding a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "IndicateUnderstanding"@en ;
    rdfs:comment "Speaker signals that they have understood the addressee's utterance."@en ;
    uckb:belongsToDimension iso:dim_partner_comm ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "IndicateUnderstanding" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "partnercomm" ;
