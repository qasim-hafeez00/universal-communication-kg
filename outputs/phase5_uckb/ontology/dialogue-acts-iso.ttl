iso:dep_da_disagreement_da_proposal a owl:NamedIndividual,
        uckb:FunctionalDependency ;
    uckb:dependencyType "responds-to" ;
    uckb:functionalDependency iso:da_proposal .

iso:dep_da_disconfirm_da_inform a owl:NamedIndividual,
        uckb:FunctionalDependency ;
    uckb:dependencyType "responds-to" ;
    uckb:functionalDependency iso:da_inform .

iso:dep_da_farewell_da_goodbye a owl:NamedIndividual,
        uckb:FunctionalDependency ;
    uckb:dependencyType "responds-to" ;
    uckb:functionalDependency iso:da_goodbye .

iso:dep_da_goodbye_da_greeting a owl:NamedIndividual,
        uckb:FunctionalDependency ;
    uckb:dependencyType "initiates" ;
    uckb:functionalDependency iso:da_greeting .

iso:dep_da_indicate_understanding_da_inform a owl:NamedIndividual,
        uckb:FunctionalDependency ;
    uckb:dependencyType "responds-to" ;
    uckb:functionalDependency iso:da_inform .

iso:dep_da_request_repair_da_inform a owl:NamedIndividual,
        uckb:FunctionalDependency ;
    uckb:dependencyType "responds-to" ;
    uckb:functionalDependency iso:da_inform .

iso:dep_da_stalling_da_request a owl:NamedIndividual,
        uckb:FunctionalDependency ;
    uckb:dependencyType "responds-to" ;
    uckb:functionalDependency iso:da_request .

iso:dep_da_take_turn_da_offer_turn a owl:NamedIndividual,
        uckb:FunctionalDependency ;
    uckb:dependencyType "responds-to" ;
    uckb:functionalDependency iso:da_offer_turn .

iso:dep_da_welcome_da_thanking a owl:NamedIndividual,
        uckb:FunctionalDependency ;
    uckb:dependencyType "responds-to" ;
    uckb:functionalDependency iso:da_thanking .

uckb:DialogueActsOntology a owl:Ontology ;
    rdfs:label "UCKB Dialogue Acts — ISO 24617-2"@en ;
    dc:description "OWL ontology defining the ISO 24617-2 dialogue act taxonomy for the Universal Communication Knowledge Base. Extends Phase 3 communication-acts.ttl."@en ;
    dc:title "UCKB Phase 5: Dialogue Acts & ISO 24617-2"@en .

iso:dim_partner_comm a owl:NamedIndividual,
        uckb:DialogueDimension ;
    rdfs:label "PartnerComm"@en ;
    rdfs:comment "Acts addressing the partner's contribution or communication difficulties."@en ;
    uckb:id "dim_partner_comm" .

iso:da_proposal a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Proposal"@en ;
    rdfs:comment "Speaker proposes a course of action for addressee to accept or reject. Requires rapport/empathy prerequisite in high-stakes domains."@en ;
    uckb:belongsToDimension iso:dim_task ;
    uckb:certainty "uncertain" ;
    uckb:communicativeFunction "Proposal" ;
    uckb:conditionality "if-then" ;
    uckb:dimension "task" ;
    uckb:id "da_proposal" ;
    uckb:requiresGrounding true ;
    uckb:requiresInfluencePrereq true ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Agent" .

iso:da_request a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Request"@en ;
    rdfs:comment "Speaker asks addressee to perform an action or provide information."@en ;
    uckb:belongsToDimension iso:dim_task ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "Request" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "task" ;
    uckb:id "da_request" ;
    uckb:requiresGrounding true ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Either" .

iso:dim_own_comm a owl:NamedIndividual,
        uckb:DialogueDimension ;
    rdfs:label "OwnComm"@en ;
    rdfs:comment "Acts by which a speaker manages their own ongoing contribution (self-repair, stalling)."@en ;
    uckb:id "dim_own_comm" .

iso:dim_feedback a owl:NamedIndividual,
        uckb:DialogueDimension ;
    rdfs:label "Feedback"@en ;
    rdfs:comment "Acts signalling whether a preceding act has been understood and accepted."@en ;
    uckb:id "dim_feedback" .

iso:dim_turn_taking a owl:NamedIndividual,
        uckb:DialogueDimension ;
    rdfs:label "TurnTaking"@en ;
    rdfs:comment "Acts that manage the allocation and transfer of speaking turns."@en ;
    uckb:id "dim_turn_taking" .

uckb:DialogueDimension a owl:Class ;
    rdfs:label "Dialogue Dimension"@en ;
    rdfs:isDefinedBy uckb:DialogueActsOntology .

iso:dim_social a owl:NamedIndividual,
        uckb:DialogueDimension ;
    rdfs:label "SocialObligations"@en ;
    rdfs:comment "Conventional social acts governed by social norms and politeness obligations."@en ;
    uckb:id "dim_social" .

iso:da_inform a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Inform"@en ;
    rdfs:comment "Speaker asserts a proposition as true for the addressee's benefit."@en ;
    uckb:belongsToDimension iso:dim_task ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "Inform" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "task" ;
    uckb:id "da_inform" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Either" .

iso:dim_task a owl:NamedIndividual,
        uckb:DialogueDimension ;
    rdfs:label "Task"@en ;
    rdfs:comment "Acts that directly advance the task or information exchange. The primary functional dimension."@en ;
    uckb:id "dim_task" .

uckb:DialogueAct a owl:Class ;
    rdfs:label "Dialogue Act"@en ;
    rdfs:isDefinedBy uckb:DialogueActsOntology .

