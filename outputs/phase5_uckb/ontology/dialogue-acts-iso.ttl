    uckb:conditionality "unconditional" ;
    uckb:dimension "turntaking" ;
    uckb:id "da_give_turn" ;
    uckb:requiresGrounding false ;
    uckb:requiresInfluencePrereq false ;
    uckb:sentiment "neutral" ;
    uckb:typicalSender "Either" .

iso:da_hold_turn a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "HoldTurn"@en ;
    rdfs:comment "Speaker signals intent to continue their turn (backchannels, fillers)."@en ;
    uckb:belongsToDimension iso:dim_turn_taking ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "HoldTurn" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "turntaking" ;
    uckb:id "da_hold_turn" ;
    uckb:requiresGrounding false ;
