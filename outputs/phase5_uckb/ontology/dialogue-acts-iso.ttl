iso:da_farewell a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Farewell"@en ;
    rdfs:comment "Speaker signals the end of an interaction with a culturally appropriate closing ritual."@en ;
    uckb:belongsToDimension iso:dim_social ;
