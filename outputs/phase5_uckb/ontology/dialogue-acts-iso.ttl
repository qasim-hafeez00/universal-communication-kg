iso:da_disconfirm a owl:NamedIndividual,
        uckb:DialogueAct ;
    rdfs:label "Disconfirm"@en ;
    rdfs:comment "Speaker denies or corrects a proposition previously asserted."@en ;
    uckb:belongsToDimension iso:dim_task ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "Disconfirm" ;
    uckb:conditionality "unconditional" ;
    uckb:dimension "task" ;
    uckb:functionalDependency iso:dep_da_disconfirm_da_inform ;
