    rdfs:label "Greeting"@en ;
    rdfs:comment "Conventional opening act establishing social contact."@en ;
    uckb:belongsToDimension iso:dim_social ;
    uckb:certainty "certain" ;
    uckb:communicativeFunction "Greeting" ;
    uckb:conditionality "unconditional" ;
