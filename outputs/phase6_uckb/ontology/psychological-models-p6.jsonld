    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Transactional Analysis ego state (Berne 1961). One of: Adapted Child, Critical Parent, Nurturing Parent, Adult."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "EgoState"
      }
