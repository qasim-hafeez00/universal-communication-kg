cc:adaptsFor a owl:ObjectProperty ;
    rdfs:comment "Links a Technique to the CulturalContext it is preferred in" .

cc:agentAdaptation a owl:DatatypeProperty ;
    rdfs:comment "Agent response strategy when this style is detected" ;
    rdfs:range xsd:string .

cc:agentBehavior a owl:DatatypeProperty ;
    rdfs:comment "Prescribed agent behavior when rule activates" ;
    rdfs:range xsd:string .

cc:appliesRule a owl:ObjectProperty ;
    rdfs:comment "Links CulturalProfile/CulturalContext to a CulturalAdaptationRule" .

cc:faceSaving a owl:DatatypeProperty ;
    rdfs:comment "Whether face-saving is a primary cultural driver" ;
    rdfs:range xsd:boolean .

cc:hallContextLevel a owl:DatatypeProperty ;
    rdfs:comment "Hall's context level: 'high' or 'low'" ;
    rdfs:range xsd:string .

cc:hasDimension a owl:ObjectProperty ;
    rdfs:comment "Links CulturalProfile to a CulturalContext dimensional descriptor" .

cc:hofstedeIDV a owl:DatatypeProperty ;
    rdfs:comment "Hofstede Individualism score (0-100)" ;
    rdfs:range xsd:integer .

cc:hofstedeIVR a owl:DatatypeProperty ;
    rdfs:comment "Hofstede Indulgence score (0-100)" ;
    rdfs:range xsd:integer .

cc:hofstedeLTO a owl:DatatypeProperty ;
    rdfs:comment "Hofstede Long-Term Orientation (0-100)" ;
    rdfs:range xsd:integer .

cc:hofstedeMAS a owl:DatatypeProperty ;
    rdfs:comment "Hofstede Masculinity score (0-100)" ;
    rdfs:range xsd:integer .

cc:hofstedePDI a owl:DatatypeProperty ;
    rdfs:comment "Hofstede Power Distance Index (0-100)" ;
    rdfs:range xsd:integer .

cc:hofstedeUAI a owl:DatatypeProperty ;
    rdfs:comment "Hofstede Uncertainty Avoidance Index (0-100)" ;
    rdfs:range xsd:integer .

cc:indirectCommunication a owl:DatatypeProperty ;
    rdfs:comment "Whether indirect communication is the norm" ;
    rdfs:range xsd:boolean .

cc:lewisModel a owl:DatatypeProperty ;
    rdfs:comment "Lewis model type: linear-active|multi-active|reactive" ;
    rdfs:range xsd:string .

cc:preferredEvidence a owl:DatatypeProperty ;
    rdfs:comment "emotional | factual | mixed" ;
    rdfs:range xsd:string .

cc:prefersStyle a owl:ObjectProperty ;
    rdfs:comment "CulturalContext dimensional node predicts this CommunicationStyle" .

cc:primaryStyle a owl:DatatypeProperty ;
    rdfs:comment "CommunicationStyle name this profile represents" ;
    rdfs:range xsd:string .

cc:recalibrateIn a owl:ObjectProperty ;
    rdfs:comment "Nonverbal signal meaning must be reinterpreted in this CulturalContext" .

cc:styleSuggests a owl:ObjectProperty ;
    rdfs:comment "Links BehavioralStyleProfile to a recommended Technique" .

cc:timeOrientation a owl:DatatypeProperty ;
    rdfs:comment "monochronic or polychronic" ;
    rdfs:range xsd:string .

cc:trigger a owl:DatatypeProperty ;
    rdfs:comment "Cultural dimension(s) or event that activates this rule" ;
    rdfs:range xsd:string .

cc:CulturalProfile a owl:Class ;
    rdfs:label "Cultural Profile" ;
    rdfs:comment "A named regional or national cultural cluster aggregating Hofstede dimensional scores and communication style descriptors." ;
    rdfs:subClassOf uckb:PsychologicalConstruct .

