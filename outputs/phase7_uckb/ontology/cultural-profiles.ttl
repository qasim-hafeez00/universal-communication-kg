@prefix cc: <https://uckb.io/ontology/crosscultural#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix uckb: <https://uckb.io/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cc:CulturalAdaptationRule a owl:Class ;
    rdfs:label "Cultural Adaptation Rule" ;
    rdfs:comment "A specific behavioral change the agent applies when interacting within a given cultural context." ;
    rdfs:subClassOf uckb:PsychologicalConstruct .

cc:CultureArabWorld a owl:NamedIndividual,
        cc:CulturalProfile ;
    rdfs:label "Arab World" ;
    cc:createdInPhase 7 ;
    cc:faceSaving true ;
    cc:geographicRegions "Middle East, North Africa, Gulf States" ;
    cc:hallContextLevel "high" ;
    cc:hofstedeIDV 38 ;
    cc:hofstedeIVR 34 ;
    cc:hofstedeLTO 23 ;
    cc:hofstedeMAS 53 ;
    cc:hofstedePDI 80 ;
    cc:hofstedeUAI 68 ;
    cc:indirectCommunication true ;
    cc:lewisModel "multi-active" ;
    cc:timeOrientation "polychronic" .

